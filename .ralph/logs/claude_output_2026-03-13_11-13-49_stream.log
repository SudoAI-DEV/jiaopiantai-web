{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_wqteffuorefe_1","type":"tool_result","content":"     1→import Link from \"next/link\";\n     2→import { getSession } from \"@/lib/auth-utils\";\n     3→import { db } from \"@/lib/db\";\n     4→import { userProfiles, products } from \"@/lib/db/schema\";\n     5→import { eq, desc, sql, like, or, and } from \"drizzle-orm\";\n     6→import { Card, CardContent } from \"@/components/ui/card\";\n     7→import { Input } from \"@/components/ui/input\";\n     8→\n     9→const statusOptions = [\n    10→  { value: \"\", label: \"全部状态\" },\n    11→  { value: \"draft\", label: \"草稿\" },\n    12→  { value: \"submitted\", label: \"已提交\" },\n    13→  { value: \"queued\", label: \"入队中\" },\n    14→  { value: \"processing\", label: \"生成中\" },\n    15→  { value: \"reviewing\", label: \"审核中\" },\n    16→  { value: \"client_reviewing\", label: \"待核对\" },\n    17→  { value: \"completed\", label: \"已完成\" },\n    18→  { value: \"failed\", label: \"失败\" },\n    19→];\n    20→\n    21→const categoryLabels: Record<string, string> = {\n    22→  clothing: \"服装\",\n    23→  accessories: \"饰品\",\n    24→  shoes: \"鞋类\",\n    25→  bags: \"箱包\",\n    26→  electronics: \"电子产品\",\n    27→  home: \"家居用品\",\n    28→  beauty: \"美妆护肤\",\n    29→  food: \"食品饮料\",\n    30→  other: \"其他\",\n    31→};\n    32→\n    33→const statusLabels: Record<string, string> = {\n    34→  draft: \"草稿\",\n    35→  submitted: \"已提交\",\n    36→  queued: \"入队中\",\n    37→  processing: \"生成中\",\n    38→  reviewing: \"审核中\",\n    39→  client_reviewing: \"待核对\",\n    40→  feedback_received: \"待返工\",\n    41→  reworking: \"返工中\",\n    42→  completed: \"已完成\",\n    43→  failed: \"失败\",\n    44→  cancelled: \"已取消\",\n    45→};\n    46→\n    47→const statusColors: Record<string, string> = {\n    48→  draft: \"bg-gray-100 text-gray-600\",\n    49→  submitted: \"bg-blue-100 text-blue-600\",\n    50→  queued: \"bg-indigo-100 text-indigo-600\",\n    51→  processing: \"bg-yellow-100 text-yellow-600\",\n    52→  reviewing: \"bg-purple-100 text-purple-600\",\n    53→  client_reviewing: \"bg-teal-100 text-teal-600\",\n    54→  feedback_received: \"bg-orange-100 text-orange-600\",\n    55→  reworking: \"bg-orange-100 text-orange-600\",\n    56→  completed: \"bg-green-100 text-green-600\",\n    57→  failed: \"bg-red-100 text-red-600\",\n    58→  cancelled: \"bg-gray-100 text-gray-600\",\n    59→};\n    60→\n    61→async function getProducts(search?: string, status?: string, userId?: string) {\n    62→  const conditions: any[] = [];\n    63→\n    64→  if (search) {\n    65→    conditions.push(\n    66→      or(\n    67→        like(products.name, `%${search}%`),\n    68→        like(products.productNumber, `%${search}%`),\n    69→        like(userProfiles.shopName, `%${search}%`)\n    70→      )\n    71→    );\n    72→  }\n    73→\n    74→  if (status) {\n    75→    conditions.push(eq(products.status, status as any));\n    76→  }\n    77→\n    78→  if (userId) {\n    79→    conditions.push(eq(products.userId, userId));\n    80→  }\n    81→\n    82→  const result = await db\n    83→    .select({\n    84→      id: products.id,\n    85→      productNumber: products.productNumber,\n    86→      name: products.name,\n    87→      category: products.category,\n    88→      status: products.status,\n    89→      deliveryCount: products.deliveryCount,\n    90→      userId: products.userId,\n    91→      createdAt: products.createdAt,\n    92→      shopName: userProfiles.shopName,\n    93→      email: userProfiles.id,\n    94→    })\n    95→    .from(products)\n    96→    .leftJoin(userProfiles, eq(products.userId, userProfiles.id))\n    97→    .where(conditions.length > 0 ? and(...conditions) : undefined)\n    98→    .orderBy(desc(products.createdAt));\n    99→  return result;\n   100→}\n   101→\n   102→export default async function AdminProductsPage({\n   103→  searchParams,\n   104→}: {\n   105→  searchParams: Promise<{ search?: string; status?: string; userId?: string }>;\n   106→}) {\n   107→  const { search, status, userId } = await searchParams;\n   108→  const productsList = await getProducts(search, status, userId);\n   109→\n   110→  return (\n   111→    <div className=\"space-y-6\">\n   112→      {/* Header */}\n   113→      <div>\n   114→        <h1 className=\"text-2xl font-bold text-[#4E342E]\">产品管理</h1>\n   115→        <p className=\"text-gray-600\">查看和管理所有产品</p>\n   116→      </div>\n   117→\n   118→      {/* Filters */}\n   119→      <form className=\"flex flex-wrap gap-2\">\n   120→        <Input\n   121→          name=\"search\"\n   122→          placeholder=\"搜索产品名称、编号、店铺...\"\n   123→          defaultValue={search}\n   124→          className=\"max-w-xs\"\n   125→        />\n   126→        <select\n   127→          name=\"status\"\n   128→          defaultValue={status}\n   129→          className=\"px-3 py-2 border border-gray-300 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-[#FDD835]\"\n   130→        >\n   131→          {statusOptions.map((opt) => (\n   132→            <option key={opt.value} value={opt.value}>\n   133→              {opt.label}\n   134→            </option>\n   135→          ))}\n   136→        </select>\n   137→        <button\n   138→          type=\"submit\"\n   139→          className=\"px-4 py-2 bg-[#FDD835] text-[#4E342E] font-medium rounded-lg hover:bg-[#FDD835]/90\"\n   140→        >\n   141→          筛选\n   142→        </button>\n   143→        {search || status ? (\n   144→          <Link\n   145→            href=\"/admin/products\"\n   146→            className=\"px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50\"\n   147→          >\n   148→            清除\n   149→          </Link>\n   150→        ) : null}\n   151→      </form>\n   152→\n   153→      {/* Product List */}\n   154→      <Card>\n   155→        <CardContent className=\"p-0\">\n   156→          <div className=\"overflow-x-auto\">\n   157→            <tab