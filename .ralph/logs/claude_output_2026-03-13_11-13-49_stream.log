{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_pl77nws68t9b_1","type":"tool_result","content":"File created successfully at: /Users/yepingzheng/SudoAI/jiaopiantai/src/components/task-status-poller.tsx"}]},"parent_tool_use_id":null,"session_id":"0fe3e04a-e649-4c3b-ad04-3a2fa78bad13","uuid":"1bc6cd90-92c4-4447-b6cb-0459d3ff7ea1","tool_use_result":{"type":"create","filePath":"/Users/yepingzheng/SudoAI/jiaopiantai/src/components/task-status-poller.tsx","content":"\"use client\";\n\nimport { useEffect, useState } from \"react\";\nimport { useRouter } from \"next/navigation\";\n\ninterface TaskStatusPollerProps {\n  productId: string;\n  statuses: string[];\n  pollInterval?: number;\n}\n\nexport function TaskStatusPoller({\n  productId,\n  statuses,\n  pollInterval = 5000,\n}: TaskStatusPollerProps) {\n  const router = useRouter();\n  const [isPolling, setIsPolling] = useState(false);\n\n  useEffect(() => {\n    // Only poll if product is in a status that needs polling\n    if (!statuses.includes(\"submitted\") && !statuses.includes(\"queued\") && !statuses.includes(\"processing\")) {\n      return;\n    }\n\n    setIsPolling(true);\n\n    const pollStatus = async () => {\n      try {\n        const res = await fetch(`/api/ai/tasks?productId=${productId}`);\n        if (res.ok) {\n          const data = await res.json();\n\n          // If task is completed or failed, stop polling and refresh\n          if (data.status === \"completed\" || data.status === \"failed\") {\n            setIsPolling(false);\n            router.refresh();\n            return;\n          }\n\n          // If status changed from what we started with, refresh\n          if (!statuses.includes(data.status)) {\n            router.refresh();\n          }\n        }\n      } catch (error) {\n        console.error(\"Poll error:\", error);\n      }\n    };\n\n    const interval = setInterval(pollStatus, pollInterval);\n\n    // Initial poll\n    pollStatus();\n\n    return () => {\n      clearInterval(interval);\n      setIsPolling(false);\n    };\n  }, [productId, statuses, pollInterval, router]);\n\n  if (!isPolling) return null;\n\n  return (\n    <div className=\"fixed bottom-4 right-4 bg-white shadow-lg rounded-lg p-4 z-50\">\n      <div className=\"flex items-center gap-2 text-sm text-gray-600\">\n        <div className=\"w-2 h-2 bg-blue-500 rounded-full animate-pulse\" />\n        <span>正在同步状态...</span>\n      </div>\n    </div>\n  );\n}\n","structuredPatch":[],"originalFile":null}}
