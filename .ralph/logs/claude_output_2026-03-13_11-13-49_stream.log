{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_yefmbkp9g8zj_1","type":"tool_result","content":"     1→import Link from \"next/link\";\n     2→import { getSession } from \"@/lib/auth-utils\";\n     3→import { db } from \"@/lib/db\";\n     4→import { products, productSourceImages, productGeneratedImages } from \"@/lib/db/schema\";\n     5→import { eq, and } from \"drizzle-orm\";\n     6→import Image from \"next/image\";\n     7→import { notFound } from \"next/navigation\";\n     8→\n     9→const statusLabels: Record<string, string> = {\n    10→  draft: \"草稿\",\n    11→  submitted: \"已提交\",\n    12→  queued: \"入队中\",\n    13→  processing: \"生成中\",\n    14→  reviewing: \"审核中\",\n    15→  client_reviewing: \"待核对\",\n    16→  feedback_received: \"待返工\",\n    17→  reworking: \"返工中\",\n    18→  completed: \"已完成\",\n    19→  failed: \"失败\",\n    20→  cancelled: \"已取消\",\n    21→};\n    22→\n    23→const categoryLabels: Record<string, string> = {\n    24→  clothing: \"服装\",\n    25→  accessories: \"饰品\",\n    26→  shoes: \"鞋类\",\n    27→  bags: \"箱包\",\n    28→  electronics: \"电子产品\",\n    29→  home: \"家居用品\",\n    30→  beauty: \"美妆护肤\",\n    31→  food: \"食品饮料\",\n    32→  other: \"其他\",\n    33→};\n    34→\n    35→export default async function ProductDetailPage({\n    36→  params,\n    37→}: {\n    38→  params: Promise<{ id: string }>;\n    39→}) {\n    40→  const session = await getSession();\n    41→  if (!session?.user) return null;\n    42→\n    43→  const { id } = await params;\n    44→\n    45→  const product = await db.query.products.findFirst({\n    46→    where: and(eq(products.id, id), eq(products.userId, session.user.id)),\n    47→  });\n    48→\n    49→  if (!product) {\n    50→    notFound();\n    51→  }\n    52→\n    53→  const [sourceImages, generatedImages] = await Promise.all([\n    54→    db\n    55→      .select()\n    56→      .from(productSourceImages)\n    57→      .where(eq(productSourceImages.productId, id))\n    58→      .orderBy(productSourceImages.sortOrder),\n    59→    db\n    60→      .select()\n    61→      .from(productGeneratedImages)\n    62→      .where(eq(productGeneratedImages.productId, id))\n    63→      .orderBy(productGeneratedImages.sortOrder),\n    64→  ]);\n    65→\n    66→  const approvedImages = generatedImages.filter(\n    67→    (img) => img.reviewStatus === \"approved\"\n    68→  );\n    69→\n    70→  return (\n    71→    <div className=\"space-y-6\">\n    72→      {/* Header */}\n    73→      <div className=\"flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4\">\n    74→        <div>\n    75→          <Link\n    76→            href=\"/products\"\n    77→            className=\"text-sm text-gray-600 hover:text-[#4E342E] flex items-center gap-1\"\n    78→          >\n    79→            ← 返回产品列表\n    80→          </Link>\n    81→          <div className=\"flex items-center gap-3 mt-2\">\n    82→            <h1 className=\"text-2xl font-bold text-[#4E342E]\">\n    83→              {product.name}\n    84→            </h1>\n    85→            <span className=\"px-2 py-1 bg-gray-100 text-gray-600 text-sm rounded\">\n    86→              {product.productNumber}\n    87→            </span>\n    88→          </div>\n    89→          <p className=\"text-gray-600 mt-1\">\n    90→            {categoryLabels[product.category] || product.category} ·{\" \"}\n    91→            {statusLabels[product.status] || product.status}\n    92→          </p>\n    93→        </div>\n    94→\n    95→        {product.status === \"draft\" && (\n    96→          <form action={`/api/products/${id}/submit`} method=\"POST\">\n    97→            <button\n    98→              type=\"submit\"\n    99→              className=\"px-4 py-2 bg-[#FDD835] text-[#4E342E] font-medium rounded-lg hover:bg-[#FDD835]/90\"\n   100→            >\n   101→              提交审核\n   102→            </button>\n   103→          </form>\n   104→        )}\n   105→      </div>\n   106→\n   107→      {/* Product Info */}\n   108→      <div className=\"bg-white rounded-xl p-6 shadow-sm\">\n   109→        <h2 className=\"text-lg font-semibold text-[#4E342E] mb-4\">\n   110→          产品信息\n   111→        </h2>\n   112→        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4 text-sm\">\n   113→          <div>\n   114→            <span className=\"text-gray-500\">产品名称</span>\n   115→            <p className=\"text-[#4E342E]\">{product.name}</p>\n   116→          </div>\n   117→          <div>\n   118→            <span className=\"text-gray-500\">产品类目</span>\n   119→            <p className=\"text-[#4E342E]\">\n   120→              {categoryLabels[product.category] || product.category}\n   121→            </p>\n   122→          </div>\n   123→          {product.description && (\n   124→            <div className=\"md:col-span-2\">\n   125→              <span className=\"text-gray-500\">产品描述</span>\n   126→              <p className=\"text-[#4E342E]\">{product.description}</p>\n   127→            </div>\n   128→          )}\n   129→          <div className=\"md:col-span-2\">\n   130→            <span className=\"text-gray-500\">拍摄需求</span>\n   131→            <p className=\"text-[#4E342E]\">{product.shootingRequirements}</p>\n   132→          </div>\n   133→          {product.specialNotes && (\n   134→            <div className=\"md:col-span-2\">\n   135→              <span className=\"text-gray-500\">特别注意事项</span>\n   136→              <p className=\"text-[#4E342E]\">{product.specialNotes}</p>\n   137→            </div>\n   138→          )}\n   139→          <div>\n   140→            <span className=\"text-gray-500\">期望交付</span>\n   141→            <p className=\"text-[#4E342E]\">{product.deliveryCount} 张</p>\n   142→          </div>\n   143→        </div>\n   144→      </div>\n   145→\n   146→      {/* Source Images */}\n   147→      <div className=\"bg-white rounded-xl p-6 shadow-sm\">\n   148→        <h2 className=\"text-lg font-semibold text-[#4E342E] mb-4\">\n   149→          原始图片 ({sourceImages.length})\n   150→        </h2>\n   151→        {sourceImages.length === 0 ? (\n   152→          <p className=\"text-gray-500\">暂无原始图片</p>\n   153→        ) : (\n   154→          <div className=\"grid grid-cols-2 md:grid-cols-4 gap-4\">\n   155→            {sourceImages.map((img) => (\n   156→              <div\n   157→                key={img.id}\n   158→                className=\"aspect-square relative rounded-lg overflow-hidden bg-gray-100\"\n   159→              >\n   160→                <Image\n   161→                  src={img.url}\n   162→                  alt={img.fileName}\n   163→                  fill\n   164→                  className=\"object-cover\"\n   165→                />\n   166→              </div>\n   167→            ))}\n   168→          </div>\n   169→        )}\n   170→      </div>\n   171→\n   172→      {/* Generated Images */}\n   173→      <div className=\"bg-white rounded-xl p-6 shadow-sm\">\n   174→        <div className=\"flex items-center justify-between mb-4\">\n   175→          <h2 className=\"text-lg font-semibold text-[#4E342E]\">\n   176→            生成结果 ({approvedImages.length}/{product.deliveryCount})\n   177→          </h2>\n   178→        </div>\n   179→\n   180→        {generatedImages.length === 0 ? (\n   181→          <div className=\"text-center py-8\">\n   182→            <div className=\"text-4xl mb-3\">🎨</div>\n   183→            <p className=\"text-gray-500\">\n   184→              {product.status === \"draft\"\n   185→                ? \"请先提交产品\"\n   186→                : product.status === \"processing\"\n   187→                ? \"AI 正在生成中，请稍候...\"\n   188→                : \"等待生成...\"}\n   189→            </p>\n   190→          </div>\n   191→        ) : (\n   192→          <div className=\"grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4\">\n   193→            {generatedImages.map((img) => (\n   194→              <div\n   195→                key={img.id}\n   196→                className={`relative aspect-[3/4] rounded-lg overflow-hidden bg-gray-100 ${\n   197→                  img.reviewStatus === \"approved\"\n   198→                    ? \"ring-2 ring-green-500\"\n   199→                    : img.reviewStatus === \"rejected\"\n   200→                    ? \"opacity-50\"\n   201→                    : \"\"\n   202→                }`}\n   203→              >\n   204→                <Image\n   205→                  src={img.url}\n   206→                  alt=\"Generated\"\n   207→                  fill\n   208→                  className=\"object-cover\"\n   209→                />\n   210→                {img.reviewStatus === \"approved\" && (\n   211→                  <div className=\"absolute top-2 right-2 bg-green-500 text-white text-xs px-2 py-1 rounded-full\">\n   212→                    ✓ 已通过\n   213→                  </div>\n   214→                )}\n   215→                {img.reviewStatus === \"rejected\" && (\n   216→                  <div className=\"absolute top-2 right-2 bg-red-500 text-white text-xs px-2 py-1 rounded-full\">\n   217→                    ✗ 已淘汰\n   218→                  </div>\n   219→                )}\n   220→              </div>\n   221→            ))}\n   222→          </div>\n   223→        )}\n   224→\n   225→        {/* Download Section */}\n   226→        {approvedImages.length > 0 && product.status === \"completed\" && (\n   227→          <div className=\"mt-6 pt-6 border-t\">\n   228→            <div className=\"flex items-center justify-between\">\n   229→              <p className=\"text-gray-600\">\n   230→                已通过 {approvedImages.length} 张精选图片\n   231→              </p>\n   232→              <div className=\"flex gap-2\">\n   233→                <button className=\"px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50\">\n   234→                  批量下载\n   235→                </button>\n   236→              </div>\n   237→            </div>\n   238→          </div>\n   239→        )}\n   240→      </div>\n   241→    </div>\n   242→  );\n   243→}\n   244→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"0fe3e04a-e649-4c3b-ad04-3a2fa78bad13","uuid":"c52756bf-8fb1-45a3-8f93-9d6bfb1aaa18","tool_use_result":{"type":"text","file":{"filePath":"/Users/yepingzheng/SudoAI/jiaopiantai/src/app/(customer)/products/[id]/page.tsx","content":"import Link from \"next/link\";\nimport { getSession } from \"@/lib/auth-utils\";\nimport { db } from \"@/lib/db\";\nimport { products, productSourceImages, productGeneratedImages } from \"@/lib/db/schema\";\nimport { eq, and } from \"drizzle-orm\";\nimport Image from \"next/image\";\nimport { notFound } from \"next/navigation\";\n\nconst statusLabels: Record<string, string> = {\n  draft: \"草稿\",\n  submitted: \"已提交\",\n  queued: \"入队中\",\n  processing: \"生成中\",\n  reviewing: \"审核中\",\n  client_reviewing: \"待核对\",\n  feedback_received: \"待返工\",\n  reworking: \"返工中\",\n  completed: \"已完成\",\n  failed: \"失败\",\n  cancelled: \"已取消\",\n};\n\nconst categoryLabels: Record<string, string> = {\n  clothing: \"服装\",\n  accessories: \"饰品\",\n  shoes: \"鞋类\",\n  bags: \"箱包\",\n  electronics: \"电子产品\",\n  home: \"家居用品\",\n  beauty: \"美妆护肤\",\n  food: \"食品饮料\",\n  other: \"其他\",\n};\n\nexport default async function ProductDetailPage({\n  params,\n}: {\n  params: Promise<{ id: string }>;\n}) {\n  const session = await getSession();\n  if (!session?.user) return null;\n\n  const { id } = await params;\n\n  const product = await db.query.products.findFirst({\n    where: and(eq(products.id, id), eq(products.userId, session.user.id)),\n  });\n\n  if (!product) {\n    notFound();\n  }\n\n  const [sourceImages, generatedImages] = await Promise.all([\n    db\n      .select()\n      .from(productSourceImages)\n      .where(eq(productSourceImages.productId, id))\n      .orderBy(productSourceImages.sortOrder),\n    db\n      .select()\n      .from(productGeneratedImages)\n      .where(eq(productGeneratedImages.productId, id))\n      .orderBy(productGeneratedImages.sortOrder),\n  ]);\n\n  const approvedImages = generatedImages.filter(\n    (img) => img.reviewStatus === \"approved\"\n  );\n\n  return (\n    <div className=\"space-y-6\">\n      {/* Header */}\n      <div className=\"flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4\">\n        <div>\n          <Link\n            href=\"/products\"\n            className=\"text-sm text-gray-600 hover:text-[#4E342E] flex items-center gap-1\"\n          >\n            ← 返回产品列表\n          </Link>\n          <div className=\"flex items-center gap-3 mt-2\">\n            <h1 className=\"text-2xl font-bold text-[#4E342E]\">\n              {product.name}\n            </h1>\n            <span className=\"px-2 py-1 bg-gray-100 text-gray-600 text-sm rounded\">\n              {product.productNumber}\n            </span>\n          </div>\n          <p className=\"text-gray-600 mt-1\">\n            {categoryLabels[product.category] || product.category} ·{\" \"}\n            {statusLabels[product.status] || product.status}\n          </p>\n        </div>\n\n        {product.status === \"draft\" && (\n          <form action={`/api/products/${id}/submit`} method=\"POST\">\n            <button\n              type=\"submit\"\n              className=\"px-4 py-2 bg-[#FDD835] text-[#4E342E] font-medium rounded-lg hover:bg-[#FDD835]/90\"\n            >\n              提交审核\n            </button>\n          </form>\n        )}\n      </div>\n\n      {/* Product Info */}\n      <div className=\"bg-white rounded-xl p-6 shadow-sm\">\n        <h2 className=\"text-lg font-semibold text-[#4E342E] mb-4\">\n          产品信息\n        </h2>\n        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4 text-sm\">\n          <div>\n            <span className=\"text-gray-500\">产品名称</span>\n            <p className=\"text-[#4E342E]\">{product.name}</p>\n          </div>\n          <div>\n            <span className=\"text-gray-500\">产品类目</span>\n            <p className=\"text-[#4E342E]\">\n              {categoryLabels[product.category] || product.category}\n            </p>\n          </div>\n          {product.description && (\n            <div className=\"md:col-span-2\">\n              <span className=\"text-gray-500\">产品描述</span>\n              <p className=\"text-[#4E342E]\">{product.description}</p>\n            </div>\n          )}\n          <div className=\"md:col-span-2\">\n            <span className=\"text-gray-500\">拍摄需求</span>\n            <p className=\"text-[#4E342E]\">{product.shootingRequirements}</p>\n          </div>\n          {product.specialNotes && (\n            <div className=\"md:col-span-2\">\n              <span className=\"text-gray-500\">特别注意事项</span>\n              <p className=\"text-[#4E342E]\">{product.specialNotes}</p>\n            </div>\n          )}\n          <div>\n            <span className=\"text-gray-500\">期望交付</span>\n            <p className=\"text-[#4E342E]\">{product.deliveryCount} 张</p>\n          </div>\n        </div>\n      </div>\n\n      {/* Source Images */}\n      <div className=\"bg-white rounded-xl p-6 shadow-sm\">\n        <h2 className=\"text-lg font-semibold text-[#4E342E] mb-4\">\n          原始图片 ({sourceImages.length})\n        </h2>\n        {sourceImages.length === 0 ? (\n          <p className=\"text-gray-500\">暂无原始图片</p>\n        ) : (\n          <div className=\"grid grid-cols-2 md:grid-cols-4 gap-4\">\n            {sourceImages.map((img) => (\n              <div\n                key={img.id}\n                className=\"aspect-square relative rounded-lg overflow-hidden bg-gray-100\"\n              >\n                <Image\n                  src={img.url}\n                  alt={img.fileName}\n                  fill\n                  className=\"object-cover\"\n                />\n              </div>\n            ))}\n          </div>\n        )}\n      </div>\n\n      {/* Generated Images */}\n      <div className=\"bg-white rounded-xl p-6 shadow-sm\">\n        <div className=\"flex items-center justify-between mb-4\">\n          <h2 className=\"text-lg font-semibold text-[#4E342E]\">\n            生成结果 ({approvedImages.length}/{product.deliveryCount})\n          </h2>\n        </div>\n\n        {generatedImages.length === 0 ? (\n          <div className=\"text-center py-8\">\n            <div className=\"text-4xl mb-3\">🎨</div>\n            <p className=\"text-gray-500\">\n              {product.status === \"draft\"\n                ? \"请先提交产品\"\n                : product.status === \"processing\"\n                ? \"AI 正在生成中，请稍候...\"\n                : \"等待生成...\"}\n            </p>\n          </div>\n        ) : (\n          <div className=\"grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4\">\n            {generatedImages.map((img) => (\n              <div\n                key={img.id}\n                className={`relative aspect-[3/4] rounded-lg overflow-hidden bg-gray-100 ${\n                  img.reviewStatus === \"approved\"\n                    ? \"ring-2 ring-green-500\"\n                    : img.reviewStatus === \"rejected\"\n                    ? \"opacity-50\"\n                    : \"\"\n                }`}\n              >\n                <Image\n                  src={img.url}\n                  alt=\"Generated\"\n                  fill\n                  className=\"object-cover\"\n                />\n                {img.reviewStatus === \"approved\" && (\n                  <div className=\"absolute top-2 right-2 bg-green-500 text-white text-xs px-2 py-1 rounded-full\">\n                    ✓ 已通过\n                  </div>\n                )}\n                {img.reviewStatus === \"rejected\" && (\n                  <div className=\"absolute top-2 right-2 bg-red-500 text-white text-xs px-2 py-1 rounded-full\">\n                    ✗ 已淘汰\n                  </div>\n                )}\n              </div>\n            ))}\n          </div>\n        )}\n\n        {/* Download Section */}\n        {approvedImages.length > 0 && product.status === \"completed\" && (\n          <div className=\"mt-6 pt-6 border-t\">\n            <div className=\"flex items-center justify-between\">\n              <p className=\"text-gray-600\">\n                已通过 {approvedImages.length} 张精选图片\n              </p>\n              <div className=\"flex gap-2\">\n                <button className=\"px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50\">\n                  批量下载\n                </button>\n              </div>\n            </div>\n          </div>\n        )}\n      </div>\n    </div>\n  );\n}\n","numLines":244,"startLine":1,"totalLines":244}}}
