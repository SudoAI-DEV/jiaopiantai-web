{"type":"assistant","message":{"id":"0602ab7141f0d533450c2bb73f2dc73b","type":"message","role":"assistant","content":[{"type":"tool_use","id":"call_function_hont3nopb07c_1","name":"Write","input":{"file_path":"/Users/yepingzheng/SudoAI/jiaopiantai/src/components/shared/customer-header.tsx","content":"\"use client\";\n\nimport Link from \"next/link\";\nimport { usePathname, useRouter } from \"next/navigation\";\n\ninterface HeaderProps {\n  user?: {\n    name?: string | null;\n    email?: string | null;\n  } | null;\n}\n\nconst customerNavItems = [\n  { href: \"/dashboard\", label: \"仪表盘\", icon: \"📊\" },\n  { href: \"/products\", label: \"产品管理\", icon: \"📦\" },\n  { href: \"/credits\", label: \"我的点数\", icon: \"💰\" },\n  { href: \"/profile\", label: \"个人信息\", icon: \"👤\" },\n];\n\nexport function CustomerHeader({ user }: HeaderProps) {\n  const pathname = usePathname();\n  const router = useRouter();\n\n  const handleSignOut = async () => {\n    try {\n      await fetch(\"/api/auth/sign-out\", { method: \"POST\" });\n      router.push(\"/\");\n      router.refresh();\n    } catch (err) {\n      console.error(\"Sign out error:\", err);\n    }\n  };\n\n  return (\n    <header className=\"bg-white border-b border-gray-200 sticky top-0 z-50\">\n      <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n        <div className=\"flex justify-between items-center h-16\">\n          {/* Logo */}\n          <Link href=\"/dashboard\" className=\"flex items-center\">\n            <span className=\"text-2xl font-bold text-[#FDD335]\">蕉片台</span>\n          </Link>\n\n          {/* Navigation */}\n          <nav className=\"hidden md:flex space-x-1\">\n            {customerNavItems.map((item) => (\n              <Link\n                key={item.href}\n                href={item.href}\n                className={`px-3 py-2 rounded-lg text-sm font-medium transition-colors ${\n                  pathname === item.href\n                    ? \"bg-[#FDD335]/10 text-[#4E342E]\"\n                    : \"text-gray-600 hover:bg-gray-100\"\n                }`}\n              >\n                <span className=\"mr-1\">{item.icon}</span>\n                {item.label}\n              </Link>\n            ))}\n          </nav>\n\n          {/* User Menu */}\n          <div className=\"flex items-center space-x-4\">\n            {user && (\n              <span className=\"text-sm text-gray-600 hidden sm:block\">\n                {user.name || user.email}\n              </span>\n            )}\n            <button\n              onClick={handleSignOut}\n              className=\"text-sm text-gray-600 hover:text-[#4E342E]\"\n            >\n              退出登录\n            </button>\n          </div>\n        </div>\n      </div>\n    </header>\n  );\n}\n"}}],"model":"MiniMax-M2.5","stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":144,"output_tokens":0,"cache_creation_input_tokens":784,"cache_read_input_tokens":39537},"service_tier":"standard","context_management":null},"parent_tool_use_id":null,"session_id":"a19b3cf4-17c8-49c2-b063-8916b4639b93","uuid":"f1b92d32-d60b-43b0-a58c-7ac5720e9466"}
