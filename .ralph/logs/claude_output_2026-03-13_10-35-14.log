{"type":"assistant","message":{"id":"0602aca50f796a837559606055050c02","type":"message","role":"assistant","content":[{"type":"tool_use","id":"call_function_6wezv8kw0m8x_1","name":"Write","input":{"file_path":"/Users/yepingzheng/SudoAI/jiaopiantai/src/app/(customer)/credits/page.tsx","content":"import Link from \"next/link\";\nimport { auth } from \"@/lib/auth\";\nimport { db } from \"@/lib/db\";\nimport { userProfiles, creditTransactions } from \"@/lib/db/schema\";\nimport { eq, desc } from \"drizzle-orm\";\nimport { Card, CardContent, CardHeader, CardTitle } from \"@/components/ui/card\";\n\nconst transactionLabels: Record<string, string> = {\n  recharge: \"充值\",\n  purchase: \"购买\",\n  submission: \"提交消耗\",\n  completion: \"完成确认\",\n  refund: \"退还\",\n};\n\nexport default async function CreditsPage() {\n  const session = await auth();\n  if (!session?.user) return null;\n\n  const profile = await db.query.userProfiles.findFirst({\n    where: eq(userProfiles.id, session.user.id),\n  });\n\n  if (!profile) return null;\n\n  const transactions = await db\n    .select()\n    .from(creditTransactions)\n    .where(eq(creditTransactions.userId, session.user.id))\n    .orderBy(desc(creditTransactions.createdAt))\n    .limit(50);\n\n  return (\n    <div className=\"space-y-6\">\n      {/* Header */}\n      <div>\n        <h1 className=\"text-2xl font-bold text-[#4E342E]\">我的点数</h1>\n        <p className=\"text-gray-600\">查看点数余额和交易记录</p>\n      </div>\n\n      {/* Stats Cards */}\n      <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n        <Card className=\"bg-gradient-to-br from-[#FDD835] to-[#FFC107] border-0\">\n          <CardContent className=\"p-6\">\n            <p className=\"text-sm font-medium text-[#4E342E]/70\">可用点数</p>\n            <p className=\"text-4xl font-bold text-[#4E342E] mt-2\">\n              {profile.creditsBalance}\n            </p>\n          </CardContent>\n        </Card>\n\n        <Card>\n          <CardContent className=\"p-6\">\n            <p className=\"text-sm font-medium text-gray-500\">冻结中</p>\n            <p className=\"text-4xl font-bold text-[#4E342E] mt-2\">\n              {profile.creditsFrozen}\n            </p>\n            <p className=\"text-sm text-gray-500 mt-1\">\n              提交产品后冻结\n            </p>\n          </CardContent>\n        </Card>\n\n        <Card>\n          <CardContent className=\"p-6\">\n            <p className=\"text-sm font-medium text-gray-500\">累计消耗</p>\n            <p className=\"text-4xl font-bold text-[#4E342E] mt-2\">\n              {profile.creditsTotalSpent}\n            </p>\n            <p className=\"text-sm text-gray-500 mt-1\">\n              已完成产品\n            </p>\n          </CardContent>\n        </Card>\n      </div>\n\n      {/* How to get credits */}\n      <Card>\n        <CardHeader>\n          <CardTitle>如何获得点数？</CardTitle>\n        </CardHeader>\n        <CardContent>\n          <div className=\"space-y-3\">\n            <div className=\"flex items-start gap-3\">\n              <div className=\"w-8 h-8 bg-[#FDD835]/20 rounded-full flex items-center justify-center text-[#4E342E] font-bold\">\n                1\n              </div>\n              <div>\n                <p className=\"font-medium text-[#4E342E]\">联系客服购买</p>\n                <p className=\"text-sm text-gray-500\">\n                  添加微信或电话联系客服购买点数套餐\n                </p>\n              </div>\n            </div>\n            <div className=\"flex items-start gap-3\">\n              <div className=\"w-8 h-8 bg-[#FDD835]/20 rounded-full flex items-center justify-center text-[#4E342E] font-bold\">\n                2\n              </div>\n              <div>\n                <p className=\"font-medium text-[#4E342E]\">管理员充值</p>\n                <p className=\"text-sm text-gray-500\">\n                  购买后管理员将为您充值点数到账户\n                </p>\n              </div>\n            </div>\n          </div>\n        </CardContent>\n      </Card>\n\n      {/* Transaction History */}\n      <Card>\n        <CardHeader>\n          <CardTitle>交易记录</CardTitle>\n        </CardHeader>\n        <CardContent>\n          {transactions.length === 0 ? (\n            <p className=\"text-center text-gray-500 py-8\">暂无交易记录</p>\n          ) : (\n            <div className=\"divide-y\">\n              {transactions.map((tx) => (\n                <div\n                  key={tx.id}\n                  className=\"flex items-center justify-between py-3\"\n                >\n                  <div>\n                    <p className=\"font-medium text-[#4E342E]\">\n                      {transactionLabels[tx.type] || tx.type}\n                    </p>\n                    <p className=\"text-sm text-gray-500\">\n                      {tx.description || \"-\"}\n                    </p>\n                    <p className=\"text-xs text-gray-400\">\n                      {tx.createdAt.toLocaleString(\"zh-CN\")}\n                    </p>\n                  </div>\n                  <div className=\"text-right\">\n                    <p\n                      className={`font-semibold ${\n                        tx.amount > 0 ? \"text-green-600\" : \"text-red-600\"\n                      }`}\n                    >\n                      {tx.amount > 0 ? \"+\" : \"\"}\n                      {tx.amount}\n                    </p>\n                    <p className=\"text-sm text-gray-500\">\n                      余额: {tx.balanceAfter}\n                    </p>\n                  </div>\n                </div>\n              ))}\n            </div>\n          )}\n        </CardContent>\n      </Card>\n    </div>\n  );\n}\n"}}],"model":"MiniMax-M2.5","stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":339,"output_tokens":0,"cache_creation_input_tokens":1074,"cache_read_input_tokens":54627},"service_tier":"standard","context_management":null},"parent_tool_use_id":null,"session_id":"a19b3cf4-17c8-49c2-b063-8916b4639b93","uuid":"2a05a6e6-89a3-4d9b-bb43-9448a374fc5c"}
