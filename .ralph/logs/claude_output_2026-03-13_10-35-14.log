{"type":"assistant","message":{"id":"0602ab7ed7ba89d851a26bc5ca84b613","type":"message","role":"assistant","content":[{"type":"tool_use","id":"call_function_gfznnru7i41b_1","name":"Write","input":{"file_path":"/Users/yepingzheng/SudoAI/jiaopiantai/src/app/(customer)/layout.tsx","content":"import { auth } from \"@/lib/auth\";\nimport { redirect } from \"next/navigation\";\nimport { db } from \"@/lib/db\";\nimport { userProfiles } from \"@/lib/db/schema\";\nimport { eq } from \"drizzle-orm\";\nimport { CustomerHeader } from \"@/components/shared/customer-header\";\n\nexport default async function CustomerLayout({\n  children,\n}: {\n  children: React.ReactNode;\n}) {\n  const session = await auth();\n\n  if (!session?.user) {\n    redirect(\"/login\");\n  }\n\n  // Get user profile with role check\n  const profile = await db.query.userProfiles.findFirst({\n    where: eq(userProfiles.id, session.user.id),\n  });\n\n  // Only allow customers (not admins) in customer area\n  if (profile?.role === \"admin\") {\n    redirect(\"/admin\");\n  }\n\n  return (\n    <div className=\"min-h-screen bg-[#FFF8E1]\">\n      <CustomerHeader user={session.user} />\n      <main className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8\">\n        {children}\n      </main>\n    </div>\n  );\n}\n"}}],"model":"MiniMax-M2.5","stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":143,"output_tokens":0,"cache_creation_input_tokens":1104,"cache_read_input_tokens":39946},"service_tier":"standard","context_management":null},"parent_tool_use_id":null,"session_id":"a19b3cf4-17c8-49c2-b063-8916b4639b93","uuid":"01cd95c2-b9d5-4334-9d0f-8dbaa1083ea4"}
