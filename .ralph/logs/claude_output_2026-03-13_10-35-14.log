{"type":"assistant","message":{"id":"0602accfcc380ec0c5d7d99baffc4bf0","type":"message","role":"assistant","content":[{"type":"tool_use","id":"call_function_vyiqsg1t39ky_1","name":"Write","input":{"file_path":"/Users/yepingzheng/SudoAI/jiaopiantai/src/app/(customer)/profile/page.tsx","content":"import Link from \"next/link\";\nimport { auth } from \"@/lib/auth\";\nimport { db } from \"@/lib/db\";\nimport { users, userProfiles } from \"@/lib/db/schema\";\nimport { eq } from \"drizzle-orm\";\nimport { Card, CardContent, CardHeader, CardTitle } from \"@/components/ui/card\";\n\nexport default async function ProfilePage() {\n  const session = await auth();\n  if (!session?.user) return null;\n\n  const [user, profile] = await Promise.all([\n    db.query.users.findFirst({\n      where: eq(users.id, session.user.id),\n    }),\n    db.query.userProfiles.findFirst({\n      where: eq(userProfiles.id, session.user.id),\n    }),\n  ]);\n\n  if (!user || !profile) return null;\n\n  const categoryLabels: Record<string, string> = {\n    clothing: \"服装\",\n    accessories: \"饰品\",\n    shoes: \"鞋类\",\n    bags: \"箱包\",\n    electronics: \"电子产品\",\n    home: \"家居用品\",\n    beauty: \"美妆护肤\",\n    food: \"食品饮料\",\n    other: \"其他\",\n  };\n\n  return (\n    <div className=\"max-w-2xl mx-auto space-y-6\">\n      {/* Header */}\n      <div>\n        <h1 className=\"text-2xl font-bold text-[#4E342E]\">个人信息</h1>\n        <p className=\"text-gray-600\">查看和管理您的账户信息</p>\n      </div>\n\n      {/* Account Info */}\n      <Card>\n        <CardHeader>\n          <CardTitle>账户信息</CardTitle>\n        </CardHeader>\n        <CardContent className=\"space-y-4\">\n          <div className=\"flex items-center justify-between py-2 border-b\">\n            <span className=\"text-gray-500\">邮箱</span>\n            <span className=\"text-[#4E342E]\">{user.email}</span>\n          </div>\n          <div className=\"flex items-center justify-between py-2 border-b\">\n            <span className=\"text-gray-500\">姓名</span>\n            <span className=\"text-[#4E342E]\">{user.name || \"-\"}</span>\n          </div>\n          <div className=\"flex items-center justify-between py-2 border-b\">\n            <span className=\"text-gray-500\">注册时间</span>\n            <span className=\"text-[#4E342E]\">\n              {user.createdAt.toLocaleDateString(\"zh-CN\", {\n                year: \"numeric\",\n                month: \"long\",\n                day: \"numeric\",\n              })}\n            </span>\n          </div>\n        </CardContent>\n      </Card>\n\n      {/* Shop Info */}\n      <Card>\n        <CardHeader>\n          <CardTitle>店铺信息</CardTitle>\n        </CardHeader>\n        <CardContent className=\"space-y-4\">\n          <div className=\"flex items-center justify-between py-2 border-b\">\n            <span className=\"text-gray-500\">店铺名称</span>\n            <span className=\"text-[#4E342E]\">{profile.shopName || \"-\"}</span>\n          </div>\n          <div className=\"flex items-center justify-between py-2 border-b\">\n            <span className=\"text-gray-500\">联系电话</span>\n            <span className=\"text-[#4E342E]\">{profile.phone || \"-\"}</span>\n          </div>\n          <div className=\"flex items-center justify-between py-2 border-b\">\n            <span className=\"text-gray-500\">主营类目</span>\n            <span className=\"text-[#4E342E]\">\n              {profile.category ? categoryLabels[profile.category] || profile.category : \"-\"}\n            </span>\n          </div>\n        </CardContent>\n      </Card>\n\n      {/* Credits Summary */}\n      <Card>\n        <CardHeader>\n          <CardTitle>点数概况</CardTitle>\n        </CardHeader>\n        <CardContent className=\"space-y-4\">\n          <div className=\"flex items-center justify-between py-2 border-b\">\n            <span className=\"text-gray-500\">可用点数</span>\n            <span className=\"text-[#4E342E] font-semibold\">\n              {profile.creditsBalance} 点\n            </span>\n          </div>\n          <div className=\"flex items-center justify-between py-2 border-b\">\n            <span className=\"text-gray-500\">冻结中</span>\n            <span className=\"text-[#4E342E]\">{profile.creditsFrozen} 点</span>\n          </div>\n          <div className=\"flex items-center justify-between py-2\">\n            <span className=\"text-gray-500\">累计消耗</span>\n            <span className=\"text-[#4E342E]\">{profile.creditsTotalSpent} 点</span>\n          </div>\n          <Link\n            href=\"/credits\"\n            className=\"block text-center mt-4 text-[#FDD835] hover:underline\"\n          >\n            查看详细交易记录 →\n          </Link>\n        </CardContent>\n      </Card>\n    </div>\n  );\n}\n"}}],"model":"MiniMax-M2.5","stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":144,"output_tokens":0,"cache_creation_input_tokens":1680,"cache_read_input_tokens":55935},"service_tier":"standard","context_management":null},"parent_tool_use_id":null,"session_id":"a19b3cf4-17c8-49c2-b063-8916b4639b93","uuid":"c583313a-822d-42c2-b1d1-9f81763da763"}
