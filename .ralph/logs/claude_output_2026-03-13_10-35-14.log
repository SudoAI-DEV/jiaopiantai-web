{"type":"assistant","message":{"id":"0602ac9e51361b4258f25af3fd4b2c53","type":"message","role":"assistant","content":[{"type":"tool_use","id":"call_function_hiu26h3581sr_1","name":"Write","input":{"file_path":"/Users/yepingzheng/SudoAI/jiaopiantai/src/app/api/credits/route.ts","content":"import { NextRequest, NextResponse } from \"next/server\";\nimport { auth } from \"@/lib/auth\";\nimport { db } from \"@/lib/db\";\nimport { userProfiles, creditTransactions } from \"@/lib/db/schema\";\nimport { eq, desc } from \"drizzle-orm\";\n\nexport async function GET(request: NextRequest) {\n  try {\n    const session = await auth();\n    if (!session?.user) {\n      return NextResponse.json({ error: \"Unauthorized\" }, { status: 401 });\n    }\n\n    const profile = await db.query.userProfiles.findFirst({\n      where: eq(userProfiles.id, session.user.id),\n    });\n\n    if (!profile) {\n      return NextResponse.json({ error: \"Profile not found\" }, { status: 404 });\n    }\n\n    const transactions = await db\n      .select()\n      .from(creditTransactions)\n      .where(eq(creditTransactions.userId, session.user.id))\n      .orderBy(desc(creditTransactions.createdAt))\n      .limit(50);\n\n    return NextResponse.json({\n      credits: {\n        balance: profile.creditsBalance,\n        frozen: profile.creditsFrozen,\n        totalSpent: profile.creditsTotalSpent,\n      },\n      transactions,\n    });\n  } catch (error) {\n    console.error(\"Credits error:\", error);\n    return NextResponse.json(\n      { error: \"Failed to fetch credits\" },\n      { status: 500 }\n    );\n  }\n}\n"}}],"model":"MiniMax-M2.5","stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":146,"output_tokens":0,"cache_creation_input_tokens":2766,"cache_read_input_tokens":52522},"service_tier":"standard","context_management":null},"parent_tool_use_id":null,"session_id":"a19b3cf4-17c8-49c2-b063-8916b4639b93","uuid":"94166539-25af-4935-9144-206ff512ab1d"}
