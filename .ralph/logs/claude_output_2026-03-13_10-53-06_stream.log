{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_ox594k0kjmwt_1","type":"tool_result","content":"     1→import Link from \"next/link\";\n     2→import { notFound, redirect } from \"next/navigation\";\n     3→import { getSession } from \"@/lib/auth-utils\";\n     4→import { db } from \"@/lib/db\";\n     5→import { userProfiles, products, productSourceImages, productGeneratedImages } from \"@/lib/db/schema\";\n     6→import { eq, and, asc } from \"drizzle-orm\";\n     7→import Image from \"next/image\";\n     8→import { ReviewActions } from \"./review-actions\";\n     9→\n    10→const categoryLabels: Record<string, string> = {\n    11→  clothing: \"服装\",\n    12→  accessories: \"饰品\",\n    13→  shoes: \"鞋类\",\n    14→  bags: \"箱包\",\n    15→  electronics: \"电子产品\",\n    16→  home: \"家居用品\",\n    17→  beauty: \"美妆护肤\",\n    18→  food: \"食品饮料\",\n    19→  other: \"其他\",\n    20→};\n    21→\n    22→const statusLabels: Record<string, string> = {\n    23→  draft: \"草稿\",\n    24→  submitted: \"已提交\",\n    25→  queued: \"入队中\",\n    26→  processing: \"生成中\",\n    27→  reviewing: \"审核中\",\n    28→  client_reviewing: \"待核对\",\n    29→  feedback_received: \"待返工\",\n    30→  reworking: \"返工中\",\n    31→  completed: \"已完成\",\n    32→  failed: \"失败\",\n    33→  cancelled: \"已取消\",\n    34→};\n    35→\n    36→const statusColors: Record<string, string> = {\n    37→  draft: \"bg-gray-100 text-gray-600\",\n    38→  submitted: \"bg-blue-100 text-blue-600\",\n    39→  queued: \"bg-indigo-100 text-indigo-600\",\n    40→  processing: \"bg-yellow-100 text-yellow-600\",\n    41→  reviewing: \"bg-purple-100 text-purple-600\",\n    42→  client_reviewing: \"bg-teal-100 text-teal-600\",\n    43→  feedback_received: \"bg-orange-100 text-orange-600\",\n    44→  reworking: \"bg-orange-100 text-orange-600\",\n    45→  completed: \"bg-green-100 text-green-600\",\n    46→  failed: \"bg-red-100 text-red-600\",\n    47→  cancelled: \"bg-gray-100 text-gray-600\",\n    48→};\n    49→\n    50→const reviewStatusLabels: Record<string, string> = {\n    51→  pending: \"待审核\",\n    52→  approved: \"已通过\",\n    53→  rejected: \"已淘汰\",\n    54→  regenerate: \"需重新生成\",\n    55→};\n    56→\n    57→const reviewStatusColors: Record<string, string> = {\n    58→  pending: \"bg-yellow-100 text-yellow-700\",\n    59→  approved: \"bg-green-100 text-green-700\",\n    60→  rejected: \"bg-red-100 text-red-700\",\n    61→  regenerate: \"bg-orange-100 text-orange-700\",\n    62→};\n    63→\n    64→async function getProductForReview(productId: string) {\n    65→  const product = await db.query.products.findFirst({\n    66→    where: eq(products.id, productId),\n    67→  });\n    68→\n    69→  if (!product) return null;\n    70→\n    71→  const user = await db.query.userProfiles.findFirst({\n    72→    where: eq(userProfiles.id, product.userId),\n    73→  });\n    74→\n    75→  const sourceImages = await db\n    76→    .select()\n    77→    .from(productSourceImages)\n    78→    .where(eq(productSourceImages.productId, productId))\n    79→    .orderBy(productSourceImages.sortOrder);\n    80→\n    81→  const generatedImages = await db\n    82→    .select()\n    83→    .from(productGeneratedImages)\n    84→    .where(eq(productGeneratedImages.productId, productId))\n    85→    .orderBy(asc(productGeneratedImages.sortOrder));\n    86→\n    87→  return {\n    88→    product,\n    89→    user,\n    90→    sourceImages,\n    91→    generatedImages,\n    92→  };\n    93→}\n    94→\n    95→export default async function ProductReviewPage({\n    96→  params,\n    97→}: {\n    98→  params: Promise<{ id: string }>;\n    99→}) {\n   100→  const { id } = await params;\n   101→  const data = await getProductForReview(id);\n   102→\n   103→  if (!data) {\n   104→    notFound();\n   105→  }\n   106→\n   107→  const { product, user, sourceImages, generatedImages } = data;\n   108→\n   109→  const approvedImages = generatedImages.filter((img) => img.reviewStatus === \"approved\");\n   110→  const pendingImages = generatedImages.filter((img) => img.reviewStatus === \"pending\");\n   111→  const rejectedImages = generatedImages.filter((img) => img.reviewStatus === \"rejected\");\n   112→  const regenerateImages = generatedImages.filter((img) => img.reviewStatus === \"regenerate\");\n   113→\n   114→  const canDeliver = approvedImages.length >= product.deliveryCount;\n   115→  const isEditable = [\"submitted\", \"queued\", \"processing\", \"reviewing\"].includes(product.status);\n   116→\n   117→  return (\n   118→    <div className=\"space-y-6\">\n   119→      {/* Header */}\n   120→      <div className=\"flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4\">\n   121→        <div>\n   122→          <Link\n   123→            href=\"/admin/products\"\n   124→            className=\"text-sm text-gray-600 hover:text-[#4E342E] flex items-center gap-1\"\n   125→          >\n   126→            ← 返回产品列表\n   127→          </Link>\n   128→          <div className=\"flex items-center gap-3 mt-2\">\n   129→            <h1 className=\"text-2xl font-bold text-[#4E342E]\">{product.name}</h1>\n   130→            <span className=\"px-2 py-1 bg-gray-100 text-gray-600 text-sm rounded\">\n   131→              {product.productNumber}\n   132→            </span>\n   133→          </div>\n   134→          <p className=\"text-gray-600 mt-1\">\n   135→            {user?.shopName || \"未知客户\"} · {categoryLabels[product.category] || product.category} ·{\" \"}\n   136→            <span className={statusColors[product.status]}>\n   137→              {statusLabels[product.status] || product.status}\n   138→            </span>\n   139→          </p>\n   140→        </div>\n   141→\n   142→        {/* Deliver Button */}\n   143→        {canDeliver && product.status === \"reviewing\" && (\n   144→          <div className=\"flex gap-2\">\n   145→            <ReviewActions\n   146→              productId={product.id}\n   147→              productStatus={product.status}\n   148→              approvedCount={approvedImages.length}\n   149→              deliveryCount={product.deliveryCount}\n   150→            />\n   151→          </div>\n   152→        )}\n   153→      </div>\n   154→\n   155→      {/* Stats */}\n   156→      <div className=\"grid grid-cols-2 md:grid-cols-4 gap-4\">\n   157→        <div className=\"bg-white p-4 rounded-lg shadow-sm border\">\n   158→          <p className=\"text-sm text-gray-500\">待审核</p>\n   159→          <p className=\"text-2xl font-bold text-yellow-600\">{pendingImages.length}</p>\n   160→        </div>\n   161→        <div className=\"bg-white p-4 rounded-lg shadow-sm border\">\n   162→          <p className=\"text-sm text-gray-500\">已通过</p>\n   163→          <p className=\"text-2xl font-bold text-green-600\">{approvedImages.length}</p>\n   164→        </div>\n   165→        <div className=\"bg-white p-4 rounded-lg shadow-sm border\">\n   166→          <p className=\"text-sm text-gray-500\">已淘汰</p>\n   167→          <p className=\"text-2xl font-bold text-red-600\">{rejectedImages.length}</p>\n   168→        </div>\n   169→        <div className=\"bg-white p-4 rounded-lg shadow-sm border\">\n   170→          <p className=\"text-sm text-gray-500\">需重新生成</p>\n   171→          <p className=\"text-2xl font-bold text-orange-600\">{regenerateImages.length}</p>\n   172→        </div>\n   173→      </div>\n   174→\n   175→      {/* Product Info */}\n   176→      <div className=\"bg-white rounded-xl p-6 shadow-sm\">\n   177→        <h2 className=\"text-lg font-semibold text-[#4E342E] mb-4\">产品信息</h2>\n   178→        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4 text-sm\">\n   179→          <div>\n   180→            <span className=\"text-gray-500\">拍摄需求</span>\n   181→            <p className=\"text-[#4E342E]\">{product.shootingRequirements}</p>\n   182→          </div>\n   183→          {product.specialNotes && (\n   184→            <div>\n   185→              <span className=\"text-gray-500\">特别注意事项</span>\n   186→              <p className=\"text-[#4E342E]\">{product.specialNotes}</p>\n   187→            </div>\n   188→          )}\n   189→          <div>\n   190→            <span className=\"text-gray-500\">期望交付</span>\n   191→            <p className=\"text-[#4E342E]\">{product.deliveryCount} 张 (当前通过: {approvedImages.length})</p>\n   192→          </div>\n   193→        </div>\n   194→      </div>\n   195→\n   196→      {/* Source Images */}\n   197→      {sourceImages.length > 0 && (\n   198→        <div className=\"bg-white rounded-xl p-6 shadow-sm\">\n   199→          <h2 className=\"text-lg font-semibold text-[#4E342E] mb-4\">\n   200→            原始图片 ({sourceImages.length})\n   201→          </h2>\n   202→          <div className=\"grid grid-cols-2 md:grid-cols-4 gap-4\">\n   203→            {sourceImages.map((img) => (\n   204→              <div\n   205→                key={img.id}\n   206→                className=\"aspect-square relative rounded-lg overflow-hidden bg-gray-100\"\n   207→              >\n   208→                <Image\n   209→                  src={img.url}\n   210→                  alt={img.fileName}\n   211→                  fill\n   212→                  className=\"object-cover\"\n   213→                />\n   214→              </div>\n   215→            ))}\n   216→          </div>\n   217→        </div>\n   218→      )}\n   219→\n   220→      {/* Generated Images */}\n   221→      <div className=\"bg-white rounded-xl p-6 shadow-sm\">\n   222→        <div className=\"flex items-center justify-between mb-4\">\n   223→          <h2 className=\"text-lg font-semibold text-[#4E342E]\">\n   224→            AI 生成图片 ({generatedImages.length})\n   225→          </h2>\n   226→          <div className=\"text-sm text-gray-500\">\n   227→            {canDeliver ? (\n   228→              <span className=\"text-green-600 font-medium\">✓ 已达到交付标准</span>\n   229→            ) : (\n   230→              <span>还需 {product.deliveryCount - approvedImages.length} 张通过</span>\n   231→            )}\n   232→          </div>\n   233→        </div>\n   234→\n   235→        {generatedImages.length === 0 ? (\n   236→          <div className=\"text-center py-12\">\n   237→            <div className=\"text-4xl mb-3\">🖼️</div>\n   238→            <p className=\"text-gray-500\">\n   239→              {product.status === \"processing\"\n   240→                ? \"AI 正在生成中，请稍候...\"\n   241→                : product.status === \"queued\"\n   242→                ? \"等待 AI 处理...\"\n   243→                : \"暂无生成图片\"}\n   244→            </p>\n   245→          </div>\n   246→        ) : (\n   247→          <div className=\"grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4\">\n   248→            {generatedImages.map((img) => (\n   249→              <div\n   250→                key={img.id}\n   251→                className={`relative aspect-[3/4] rounded-lg overflow-hidden bg-gray-100 group ${\n   252→                  img.reviewStatus === \"approved\"\n   253→                    ? \"ring-2 ring-green-500\"\n   254→                    : img.reviewStatus === \"rejected\"\n   255→                    ? \"opacity-60\"\n   256→                    : \"\"\n   257→                }`}\n   258→              >\n   259→                <Image\n   260→                  src={img.url}\n   261→                  alt=\"Generated\"\n   262→                  fill\n   263→                  className=\"object-cover\"\n   264→                />\n   265→\n   266→                {/* Status Badge */}\n   267→                <div className=\"absolute top-2 left-2\">\n   268→                  <span\n   269→                    className={`px-2 py-1 rounded-full text-xs font-medium ${\n   270→                      reviewStatusColors[img.reviewStatus]\n   271→                    }`}\n   272→                  >\n   273→                    {reviewStatusLabels[img.reviewStatus]}\n   274→                  </span>\n   275→                </div>\n   276→\n   277→                {/* Batch Number */}\n   278→                <div className=\"absolute top-2 right-2\">\n   279→                  <span className=\"px-2 py-1 bg-black/50 text-white text-xs rounded-full\">\n   280→                    第 {img.batchNumber} 批\n   281→                  </span>\n   282→                </div>\n   283→\n   284→                {/* Actions - Only show for pending images when status allows */}\n   285→                {isEditable && img.reviewStatus === \"pending\" && (\n   286→                  <div className=\"absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center gap-2\">\n   287→                    <button\n   288→                      onClick={`approveImage('${img.id}')`}\n   289→                      className=\"px-3 py-1.5 bg-green-500 text-white text-sm rounded-lg hover:bg-green-600\"\n   290→                    >\n   291→                      ✓ 通过\n   292→                    </button>\n   293→                    <button\n   294→                      onClick={`rejectImage('${img.id}')`}\n   295→                      className=\"px-3 py-1.5 bg-red-500 text-white text-sm rounded-lg hover:bg-red-600\"\n   296→                    >\n   297→                      ✗ 淘汰\n   298→                    </button>\n   299→                  </div>\n   300→                )}\n   301→              </div>\n   302→            ))}\n   303→          </div>\n   304→        )}\n   305→\n   306→        {/* Quick Actions */}\n   307→        {isEditable && pendingImages.length > 0 && (\n   308→          <div className=\"mt-6 pt-6 border-t flex flex-wrap gap-2\">\n   309→            <button\n   310→              onClick=\"approveAllPending()\"\n   311→              className=\"px-4 py-2 bg-green-500 text-white rounded-lg hover:bg-green-600\"\n   312→            >\n   313→              全部通过 ({pendingImages.length})\n   314→            </button>\n   315→            <button\n   316→              onClick=\"rejectAllPending()\"\n   317→              className=\"px-4 py-2 bg-red-500 text-white rounded-lg hover:bg-red-600\"\n   318→            >\n   319→              全部淘汰\n   320→            </button>\n   321→            <button\n   322→              onClick=\"regenerateAllPending()\"\n   323→              className=\"px-4 py-2 bg-orange-500 text-white rounded-lg hover:bg-orange-600\"\n   324→            >\n   325→              全部重新生成\n   326→            </button>\n   327→          </div>\n   328→        )}\n   329→      </div>\n   330→    </div>\n   331→  );\n   332→}\n   333→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"0fe3e04a-e649-4c3b-ad04-3a2fa78bad13","uuid":"9649e897-5179-4811-bb72-4a05c521d2c0","tool_use_result":{"type":"text","file":{"filePath":"/Users/yepingzheng/SudoAI/jiaopiantai/src/app/(admin)/products/[id]/review/page.tsx","content":"import Link from \"next/link\";\nimport { notFound, redirect } from \"next/navigation\";\nimport { getSession } from \"@/lib/auth-utils\";\nimport { db } from \"@/lib/db\";\nimport { userProfiles, products, productSourceImages, productGeneratedImages } from \"@/lib/db/schema\";\nimport { eq, and, asc } from \"drizzle-orm\";\nimport Image from \"next/image\";\nimport { ReviewActions } from \"./review-actions\";\n\nconst categoryLabels: Record<string, string> = {\n  clothing: \"服装\",\n  accessories: \"饰品\",\n  shoes: \"鞋类\",\n  bags: \"箱包\",\n  electronics: \"电子产品\",\n  home: \"家居用品\",\n  beauty: \"美妆护肤\",\n  food: \"食品饮料\",\n  other: \"其他\",\n};\n\nconst statusLabels: Record<string, string> = {\n  draft: \"草稿\",\n  submitted: \"已提交\",\n  queued: \"入队中\",\n  processing: \"生成中\",\n  reviewing: \"审核中\",\n  client_reviewing: \"待核对\",\n  feedback_received: \"待返工\",\n  reworking: \"返工中\",\n  completed: \"已完成\",\n  failed: \"失败\",\n  cancelled: \"已取消\",\n};\n\nconst statusColors: Record<string, string> = {\n  draft: \"bg-gray-100 text-gray-600\",\n  submitted: \"bg-blue-100 text-blue-600\",\n  queued: \"bg-indigo-100 text-indigo-600\",\n  processing: \"bg-yellow-100 text-yellow-600\",\n  reviewing: \"bg-purple-100 text-purple-600\",\n  client_reviewing: \"bg-teal-100 text-teal-600\",\n  feedback_received: \"bg-orange-100 text-orange-600\",\n  reworking: \"bg-orange-100 text-orange-600\",\n  completed: \"bg-green-100 text-green-600\",\n  failed: \"bg-red-100 text-red-600\",\n  cancelled: \"bg-gray-100 text-gray-600\",\n};\n\nconst reviewStatusLabels: Record<string, string> = {\n  pending: \"待审核\",\n  approved: \"已通过\",\n  rejected: \"已淘汰\",\n  regenerate: \"需重新生成\",\n};\n\nconst reviewStatusColors: Record<string, string> = {\n  pending: \"bg-yellow-100 text-yellow-700\",\n  approved: \"bg-green-100 text-green-700\",\n  rejected: \"bg-red-100 text-red-700\",\n  regenerate: \"bg-orange-100 text-orange-700\",\n};\n\nasync function getProductForReview(productId: string) {\n  const product = await db.query.products.findFirst({\n    where: eq(products.id, productId),\n  });\n\n  if (!product) return null;\n\n  const user = await db.query.userProfiles.findFirst({\n    where: eq(userProfiles.id, product.userId),\n  });\n\n  const sourceImages = await db\n    .select()\n    .from(productSourceImages)\n    .where(eq(productSourceImages.productId, productId))\n    .orderBy(productSourceImages.sortOrder);\n\n  const generatedImages = await db\n    .select()\n    .from(productGeneratedImages)\n    .where(eq(productGeneratedImages.productId, productId))\n    .orderBy(asc(productGeneratedImages.sortOrder));\n\n  return {\n    product,\n    user,\n    sourceImages,\n    generatedImages,\n  };\n}\n\nexport default async function ProductReviewPage({\n  params,\n}: {\n  params: Promise<{ id: string }>;\n}) {\n  const { id } = await params;\n  const data = await getProductForReview(id);\n\n  if (!data) {\n    notFound();\n  }\n\n  const { product, user, sourceImages, generatedImages } = data;\n\n  const approvedImages = generatedImages.filter((img) => img.reviewStatus === \"approved\");\n  const pendingImages = generatedImages.filter((img) => img.reviewStatus === \"pending\");\n  const rejectedImages = generatedImages.filter((img) => img.reviewStatus === \"rejected\");\n  const regenerateImages = generatedImages.filter((img) => img.reviewStatus === \"regenerate\");\n\n  const canDeliver = approvedImages.length >= product.deliveryCount;\n  const isEditable = [\"submitted\", \"queued\", \"processing\", \"reviewing\"].includes(product.status);\n\n  return (\n    <div className=\"space-y-6\">\n      {/* Header */}\n      <div className=\"flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4\">\n        <div>\n          <Link\n            href=\"/admin/products\"\n            className=\"text-sm text-gray-600 hover:text-[#4E342E] flex items-center gap-1\"\n          >\n            ← 返回产品列表\n          </Link>\n          <div className=\"flex items-center gap-3 mt-2\">\n            <h1 className=\"text-2xl font-bold text-[#4E342E]\">{product.name}</h1>\n            <span className=\"px-2 py-1 bg-gray-100 text-gray-600 text-sm rounded\">\n              {product.productNumber}\n            </span>\n          </div>\n          <p className=\"text-gray-600 mt-1\">\n            {user?.shopName || \"未知客户\"} · {categoryLabels[product.category] || product.category} ·{\" \"}\n            <span className={statusColors[product.status]}>\n              {statusLabels[product.status] || product.status}\n            </span>\n          </p>\n        </div>\n\n        {/* Deliver Button */}\n        {canDeliver && product.status === \"reviewing\" && (\n          <div className=\"flex gap-2\">\n            <ReviewActions\n              productId={product.id}\n              productStatus={product.status}\n              approvedCount={approvedImages.length}\n              deliveryCount={product.deliveryCount}\n            />\n          </div>\n        )}\n      </div>\n\n      {/* Stats */}\n      <div className=\"grid grid-cols-2 md:grid-cols-4 gap-4\">\n        <div className=\"bg-white p-4 rounded-lg shadow-sm border\">\n          <p className=\"text-sm text-gray-500\">待审核</p>\n          <p className=\"text-2xl font-bold text-yellow-600\">{pendingImages.length}</p>\n        </div>\n        <div className=\"bg-white p-4 rounded-lg shadow-sm border\">\n          <p className=\"text-sm text-gray-500\">已通过</p>\n          <p className=\"text-2xl font-bold text-green-600\">{approvedImages.length}</p>\n        </div>\n        <div className=\"bg-white p-4 rounded-lg shadow-sm border\">\n          <p className=\"text-sm text-gray-500\">已淘汰</p>\n          <p className=\"text-2xl font-bold text-red-600\">{rejectedImages.length}</p>\n        </div>\n        <div className=\"bg-white p-4 rounded-lg shadow-sm border\">\n          <p className=\"text-sm text-gray-500\">需重新生成</p>\n          <p className=\"text-2xl font-bold text-orange-600\">{regenerateImages.length}</p>\n        </div>\n      </div>\n\n      {/* Product Info */}\n      <div className=\"bg-white rounded-xl p-6 shadow-sm\">\n        <h2 className=\"text-lg font-semibold text-[#4E342E] mb-4\">产品信息</h2>\n        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4 text-sm\">\n          <div>\n            <span className=\"text-gray-500\">拍摄需求</span>\n            <p className=\"text-[#4E342E]\">{product.shootingRequirements}</p>\n          </div>\n          {product.specialNotes && (\n            <div>\n              <span className=\"text-gray-500\">特别注意事项</span>\n              <p className=\"text-[#4E342E]\">{product.specialNotes}</p>\n            </div>\n          )}\n          <div>\n            <span className=\"text-gray-500\">期望交付</span>\n            <p className=\"text-[#4E342E]\">{product.deliveryCount} 张 (当前通过: {approvedImages.length})</p>\n          </div>\n        </div>\n      </div>\n\n      {/* Source Images */}\n      {sourceImages.length > 0 && (\n        <div className=\"bg-white rounded-xl p-6 shadow-sm\">\n          <h2 className=\"text-lg font-semibold text-[#4E342E] mb-4\">\n            原始图片 ({sourceImages.length})\n          </h2>\n          <div className=\"grid grid-cols-2 md:grid-cols-4 gap-4\">\n            {sourceImages.map((img) => (\n              <div\n                key={img.id}\n                className=\"aspect-square relative rounded-lg overflow-hidden bg-gray-100\"\n              >\n                <Image\n                  src={img.url}\n                  alt={img.fileName}\n                  fill\n                  className=\"object-cover\"\n                />\n              </div>\n            ))}\n          </div>\n        </div>\n      )}\n\n      {/* Generated Images */}\n      <div className=\"bg-white rounded-xl p-6 shadow-sm\">\n        <div className=\"flex items-center justify-between mb-4\">\n          <h2 className=\"text-lg font-semibold text-[#4E342E]\">\n            AI 生成图片 ({generatedImages.length})\n          </h2>\n          <div className=\"text-sm text-gray-500\">\n            {canDeliver ? (\n              <span className=\"text-green-600 font-medium\">✓ 已达到交付标准</span>\n            ) : (\n              <span>还需 {product.deliveryCount - approvedImages.length} 张通过</span>\n            )}\n          </div>\n        </div>\n\n        {generatedImages.length === 0 ? (\n          <div className=\"text-center py-12\">\n            <div className=\"text-4xl mb-3\">🖼️</div>\n            <p className=\"text-gray-500\">\n              {product.status === \"processing\"\n                ? \"AI 正在生成中，请稍候...\"\n                : product.status === \"queued\"\n                ? \"等待 AI 处理...\"\n                : \"暂无生成图片\"}\n            </p>\n          </div>\n        ) : (\n          <div className=\"grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4\">\n            {generatedImages.map((img) => (\n              <div\n                key={img.id}\n                className={`relative aspect-[3/4] rounded-lg overflow-hidden bg-gray-100 group ${\n                  img.reviewStatus === \"approved\"\n                    ? \"ring-2 ring-green-500\"\n                    : img.reviewStatus === \"rejected\"\n                    ? \"opacity-60\"\n                    : \"\"\n                }`}\n              >\n                <Image\n                  src={img.url}\n                  alt=\"Generated\"\n                  fill\n                  className=\"object-cover\"\n                />\n\n                {/* Status Badge */}\n                <div className=\"absolute top-2 left-2\">\n                  <span\n                    className={`px-2 py-1 rounded-full text-xs font-medium ${\n                      reviewStatusColors[img.reviewStatus]\n                    }`}\n                  >\n                    {reviewStatusLabels[img.reviewStatus]}\n                  </span>\n                </div>\n\n                {/* Batch Number */}\n                <div className=\"absolute top-2 right-2\">\n                  <span className=\"px-2 py-1 bg-black/50 text-white text-xs rounded-full\">\n                    第 {img.batchNumber} 批\n                  </span>\n                </div>\n\n                {/* Actions - Only show for pending images when status allows */}\n                {isEditable && img.reviewStatus === \"pending\" && (\n                  <div className=\"absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center gap-2\">\n                    <button\n                      onClick={`approveImage('${img.id}')`}\n                      className=\"px-3 py-1.5 bg-green-500 text-white text-sm rounded-lg hover:bg-green-600\"\n                    >\n                      ✓ 通过\n                    </button>\n                    <button\n                      onClick={`rejectImage('${img.id}')`}\n                      className=\"px-3 py-1.5 bg-red-500 text-white text-sm rounded-lg hover:bg-red-600\"\n                    >\n                      ✗ 淘汰\n                    </button>\n                  </div>\n                )}\n              </div>\n            ))}\n          </div>\n        )}\n\n        {/* Quick Actions */}\n        {isEditable && pendingImages.length > 0 && (\n          <div className=\"mt-6 pt-6 border-t flex flex-wrap gap-2\">\n            <button\n              onClick=\"approveAllPending()\"\n              className=\"px-4 py-2 bg-green-500 text-white rounded-lg hover:bg-green-600\"\n            >\n              全部通过 ({pendingImages.length})\n            </button>\n            <button\n              onClick=\"rejectAllPending()\"\n              className=\"px-4 py-2 bg-red-500 text-white rounded-lg hover:bg-red-600\"\n            >\n              全部淘汰\n            </button>\n            <button\n              onClick=\"regenerateAllPending()\"\n              className=\"px-4 py-2 bg-orange-500 text-white rounded-lg hover:bg-orange-600\"\n            >\n              全部重新生成\n            </button>\n          </div>\n        )}\n      </div>\n    </div>\n  );\n}\n","numLines":333,"startLine":1,"totalLines":333}}}
