{"type":"assistant","message":{"id":"0602b05bbf5be58a749765948013c7e1","type":"message","role":"assistant","content":[{"type":"tool_use","id":"call_function_paglkhx57rzl_1","name":"Write","input":{"file_path":"/Users/yepingzheng/SudoAI/jiaopiantai/src/app/(admin)/products/[id]/review/review-actions.tsx","content":"\"use client\";\n\nimport { useState } from \"react\";\nimport { useRouter } from \"next/navigation\";\nimport { Button } from \"@/components/ui/button\";\n\ninterface ReviewActionsProps {\n  productId: string;\n  productStatus: string;\n  approvedCount: number;\n  deliveryCount: number;\n}\n\nexport function ReviewActions({\n  productId,\n  productStatus,\n  approvedCount,\n  deliveryCount,\n}: ReviewActionsProps) {\n  const router = useRouter();\n  const [loading, setLoading] = useState(false);\n  const [action, setAction] = useState<\"deliver\" | null>(null);\n\n  const handleDeliver = async () => {\n    if (!confirm(`确认交付 ${approvedCount} 张图片给客户？`)) return;\n\n    setLoading(true);\n    setAction(\"deliver\");\n\n    try {\n      const res = await fetch(`/api/admin/products/${productId}/deliver`, {\n        method: \"POST\",\n      });\n\n      if (!res.ok) {\n        const data = await res.json();\n        throw new Error(data.error || \"交付失败\");\n      }\n\n      router.refresh();\n      alert(\"交付成功！\");\n    } catch (err) {\n      alert(err instanceof Error ? err.message : \"交付失败\");\n    } finally {\n      setLoading(false);\n      setAction(null);\n    }\n  };\n\n  return (\n    <Button\n      onClick={handleDeliver}\n      disabled={loading}\n      className=\"bg-green-500 hover:bg-green-600 text-white\"\n    >\n      {loading ? \"处理中...\" : `确认交付 (${approvedCount}/${deliveryCount})`}\n    </Button>\n  );\n}\n"}}],"model":"MiniMax-M2.5","stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":148,"output_tokens":0,"cache_creation_input_tokens":3265,"cache_read_input_tokens":65446},"service_tier":"standard","context_management":null},"parent_tool_use_id":null,"session_id":"0fe3e04a-e649-4c3b-ad04-3a2fa78bad13","uuid":"fef99954-3dde-4577-a5c2-447a0a8d5467"}
