me} · {tx.description || \"-\"}\n                    </p>\n                  </div>\n                  <div className=\"text-right\">\n                    <p\n                      className={`font-medium ${\n                        tx.amount > 0 ? \"text-green-600\" : \"text-red-600\"\n                      }`}\n                    >\n                      {tx.amount > 0 ? \"+\" : \"\"}\n                      {tx.amount}\n                    </p>\n                    <p className=\"text-sm text-gray-500\">\n                      {tx.createdAt\n                        ? new Date(tx.createdAt).toLocaleString(\"zh-CN\")\n                        : \"-\"}\n                    </p>\n                  </div>\n                </div>\n              ))}\n            </div>\n          )}\n        </CardContent>\n      </Card>\n    </div>\n  );\n}\n","structuredPatch":[],"originalFile":null}}
