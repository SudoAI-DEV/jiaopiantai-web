{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_4p4d9gwp5g0v_1","type":"tool_result","content":"File created successfully at: /Users/yepingzheng/SudoAI/jiaopiantai/src/app/(admin)/customers/[id]/recharge-form.tsx"}]},"parent_tool_use_id":null,"session_id":"0fe3e04a-e649-4c3b-ad04-3a2fa78bad13","uuid":"fdfe7193-721a-4cdf-8264-df4e89b71967","tool_use_result":{"type":"create","filePath":"/Users/yepingzheng/SudoAI/jiaopiantai/src/app/(admin)/customers/[id]/recharge-form.tsx","content":"\"use client\";\n\nimport { useState } from \"react\";\nimport { Button } from \"@/components/ui/button\";\nimport { Input } from \"@/components/ui/input\";\nimport { useRouter } from \"next/navigation\";\n\ninterface RechargeFormProps {\n  customerId: string;\n  currentBalance: number;\n}\n\nexport function RechargeForm({ customerId, currentBalance }: RechargeFormProps) {\n  const router = useRouter();\n  const [amount, setAmount] = useState(\"\");\n  const [description, setDescription] = useState(\"\");\n  const [loading, setLoading] = useState(false);\n  const [error, setError] = useState(\"\");\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    setError(\"\");\n\n    const points = parseInt(amount);\n    if (!points || points <= 0) {\n      setError(\"请输入有效的点数\");\n      return;\n    }\n\n    setLoading(true);\n\n    try {\n      const res = await fetch(\"/api/admin/credits/recharge\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({\n          userId: customerId,\n          amount: points,\n          description: description || `管理员充值 ${points} 点数`,\n        }),\n      });\n\n      if (!res.ok) {\n        const data = await res.json();\n        throw new Error(data.error || \"充值失败\");\n      }\n\n      router.refresh();\n      setAmount(\"\");\n      setDescription(\"\");\n      alert(`充值成功！当前余额: ${currentBalance + points}`);\n    } catch (err) {\n      setError(err instanceof Error ? err.message : \"充值失败\");\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  return (\n    <form onSubmit={handleSubmit} className=\"space-y-4\">\n      {error && (\n        <div className=\"p-3 bg-red-50 text-red-600 text-sm rounded-lg\">{error}</div>\n      )}\n\n      <div>\n        <label className=\"text-sm text-gray-600\">充值点数</label>\n        <Input\n          type=\"number\"\n          min=\"1\"\n          value={amount}\n          onChange={(e) => setAmount(e.target.value)}\n          placeholder=\"输入点数数量\"\n          className=\"mt-1\"\n        />\n      </div>\n\n      <div>\n        <label className=\"text-sm text-gray-600\">备注 (可选)</label>\n        <Input\n          value={description}\n          onChange={(e) => setDescription(e.target.value)}\n          placeholder=\"备注说明\"\n          className=\"mt-1\"\n        />\n      </div>\n\n      <Button\n        type=\"submit\"\n        disabled={loading || !amount}\n        className=\"w-full bg-[#FDD835] text-[#4E342E] hover:bg-[#FDD835]/90\"\n      >\n        {loading ? \"充值中...\" : \"确认充值\"}\n      </Button>\n    </form>\n  );\n}\n","structuredPatch":[],"originalFile":null}}
