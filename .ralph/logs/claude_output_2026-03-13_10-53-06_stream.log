{"type":"assistant","message":{"id":"0602b0daa41519e1379a0693df77e010","type":"message","role":"assistant","content":[{"type":"tool_use","id":"call_function_1auw9chnkkho_1","name":"Write","input":{"file_path":"/Users/yepingzheng/SudoAI/jiaopiantai/src/app/(admin)/styles/page.tsx","content":"import { getSession } from \"@/lib/auth-utils\";\nimport { db } from \"@/lib/db\";\nimport { styleTemplates } from \"@/lib/db/schema\";\nimport { eq, desc } from \"drizzle-orm\";\nimport { Card, CardContent, CardHeader, CardTitle } from \"@/components/ui/card\";\nimport Image from \"next/image\";\n\nasync function getStyles() {\n  return db\n    .select()\n    .from(styleTemplates)\n    .orderBy(desc(styleTemplates.sortOrder));\n}\n\nexport default async function AdminStylesPage() {\n  const styles = await getStyles();\n\n  return (\n    <div className=\"space-y-6\">\n      {/* Header */}\n      <div className=\"flex items-center justify-between\">\n        <div>\n          <h1 className=\"text-2xl font-bold text-[#4E342E]\">风格模板管理</h1>\n          <p className=\"text-gray-600\">管理 AI 生成风格选项</p>\n        </div>\n        <button className=\"px-4 py-2 bg-[#FDD835] text-[#4E342E] font-medium rounded-lg hover:bg-[#FDD835]/90\">\n          添加新风格\n        </button>\n      </div>\n\n      {/* Styles Grid */}\n      <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n        {styles.length === 0 ? (\n          <Card className=\"col-span-full\">\n            <CardContent className=\"py-12 text-center text-gray-500\">\n              <p>暂无风格模板</p>\n              <p className=\"text-sm mt-1\">点击上方按钮添加第一个风格模板</p>\n            </CardContent>\n          </Card>\n        ) : (\n          styles.map((style) => (\n            <Card key={style.id} className=\"overflow-hidden\">\n              <div className=\"aspect-video relative bg-gray-100\">\n                {style.thumbnailUrl ? (\n                  <Image\n                    src={style.thumbnailUrl}\n                    alt={style.name}\n                    fill\n                    className=\"object-cover\"\n                  />\n                ) : (\n                  <div className=\"absolute inset-0 flex items-center justify-center text-4xl\">\n                    🎨\n                  </div>\n                )}\n                {!style.isActive && (\n                  <div className=\"absolute inset-0 bg-black/50 flex items-center justify-center\">\n                    <span className=\"text-white font-medium\">已禁用</span>\n                  </div>\n                )}\n              </div>\n              <CardContent className=\"p-4\">\n                <div className=\"flex items-start justify-between\">\n                  <div>\n                    <h3 className=\"font-semibold text-[#4E342E]\">{style.name}</h3>\n                    {style.description && (\n                      <p className=\"text-sm text-gray-500 mt-1\">{style.description}</p>\n                    )}\n                  </div>\n                  <button className=\"text-sm text-[#FDD835] hover:underline\">\n                    编辑\n                  </button>\n                </div>\n              </CardContent>\n            </Card>\n          ))\n        )}\n      </div>\n    </div>\n  );\n}\n"}}],"model":"MiniMax-M2.5","stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":144,"output_tokens":0,"cache_creation_input_tokens":2215,"cache_read_input_tokens":73666},"service_tier":"standard","context_management":null},"parent_tool_use_id":null,"session_id":"0fe3e04a-e649-4c3b-ad04-3a2fa78bad13","uuid":"81d17456-606e-45b4-b374-c150c5c8cf4f"}
