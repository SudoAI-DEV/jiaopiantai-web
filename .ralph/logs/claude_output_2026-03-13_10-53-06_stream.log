{"type":"assistant","message":{"id":"0602b01f32ba4f257cc0cda8ecfd3fb9","type":"message","role":"assistant","content":[{"type":"tool_use","id":"call_function_dllg3y2851ks_1","name":"Write","input":{"file_path":"/Users/yepingzheng/SudoAI/jiaopiantai/src/app/(admin)/products/[id]/review/page.tsx","content":"import Link from \"next/link\";\nimport { notFound, redirect } from \"next/navigation\";\nimport { getSession } from \"@/lib/auth-utils\";\nimport { db } from \"@/lib/db\";\nimport { userProfiles, products, productSourceImages, productGeneratedImages } from \"@/lib/db/schema\";\nimport { eq, and, asc } from \"drizzle-orm\";\nimport Image from \"next/image\";\nimport { ReviewActions } from \"./review-actions\";\n\nconst categoryLabels: Record<string, string> = {\n  clothing: \"服装\",\n  accessories: \"饰品\",\n  shoes: \"鞋类\",\n  bags: \"箱包\",\n  electronics: \"电子产品\",\n  home: \"家居用品\",\n  beauty: \"美妆护肤\",\n  food: \"食品饮料\",\n  other: \"其他\",\n};\n\nconst statusLabels: Record<string, string> = {\n  draft: \"草稿\",\n  submitted: \"已提交\",\n  queued: \"入队中\",\n  processing: \"生成中\",\n  reviewing: \"审核中\",\n  client_reviewing: \"待核对\",\n  feedback_received: \"待返工\",\n  reworking: \"返工中\",\n  completed: \"已完成\",\n  failed: \"失败\",\n  cancelled: \"已取消\",\n};\n\nconst statusColors: Record<string, string> = {\n  draft: \"bg-gray-100 text-gray-600\",\n  submitted: \"bg-blue-100 text-blue-600\",\n  queued: \"bg-indigo-100 text-indigo-600\",\n  processing: \"bg-yellow-100 text-yellow-600\",\n  reviewing: \"bg-purple-100 text-purple-600\",\n  client_reviewing: \"bg-teal-100 text-teal-600\",\n  feedback_received: \"bg-orange-100 text-orange-600\",\n  reworking: \"bg-orange-100 text-orange-600\",\n  completed: \"bg-green-100 text-green-600\",\n  failed: \"bg-red-100 text-red-600\",\n  cancelled: \"bg-gray-100 text-gray-600\",\n};\n\nconst reviewStatusLabels: Record<string, string> = {\n  pending: \"待审核\",\n  approved: \"已通过\",\n  rejected: \"已淘汰\",\n  regenerate: \"需重新生成\",\n};\n\nconst reviewStatusColors: Record<string, string> = {\n  pending: \"bg-yellow-100 text-yellow-700\",\n  approved: \"bg-green-100 text-green-700\",\n  rejected: \"bg-red-100 text-red-700\",\n  regenerate: \"bg-orange-100 text-orange-700\",\n};\n\nasync function getProductForReview(productId: string) {\n  const product = await db.query.products.findFirst({\n    where: eq(products.id, productId),\n  });\n\n  if (!product) return null;\n\n  const user = await db.query.userProfiles.findFirst({\n    where: eq(userProfiles.id, product.userId),\n  });\n\n  const sourceImages = await db\n    .select()\n    .from(productSourceImages)\n    .where(eq(productSourceImages.productId, productId))\n    .orderBy(productSourceImages.sortOrder);\n\n  const generatedImages = await db\n    .select()\n    .from(productGeneratedImages)\n    .where(eq(productGeneratedImages.productId, productId))\n    .orderBy(asc(productGeneratedImages.sortOrder));\n\n  return {\n    product,\n    user,\n    sourceImages,\n    generatedImages,\n  };\n}\n\nexport default async function ProductReviewPage({\n  params,\n}: {\n  params: Promise<{ id: string }>;\n}) {\n  const { id } = await params;\n  const data = await getProductForReview(id);\n\n  if (!data) {\n    notFound();\n  }\n\n  const { product, user, sourceImages, generatedImages } = data;\n\n  const approvedImages = generatedImages.filter((img) => img.reviewStatus === \"approved\");\n  const pendingImages = generatedImages.filter((img) => img.reviewStatus === \"pending\");\n  const rejectedImages = generatedImages.filter((img) => img.reviewStatus === \"rejected\");\n  const regenerateImages = generatedImages.filter((img) => img.reviewStatus === \"regenerate\");\n\n  const canDeliver = approvedImages.length >= product.deliveryCount;\n  const isEditable = [\"submitted\", \"queued\", \"processing\", \"reviewing\"].includes(product.status);\n\n  return (\n    <div className=\"space-y-6\">\n      {/* Header */}\n      <div className=\"flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4\">\n        <div>\n          <Link\n            href=\"/admin/products\"\n            className=\"text-sm text-gray-600 hover:text-[#4E342E] flex items-center gap-1\"\n          >\n            ← 返回产品列表\n          </Link>\n          <div className=\"flex items-center gap-3 mt-2\">\n            <h1 className=\"text-2xl font-bold text-[#4E342E]\">{product.name}</h1>\n            <span className=\"px-2 py-1 bg-gray-100 text-gray-600 text-sm rounded\">\n              {product.productNumber}\n            </span>\n          </div>\n          <p className=\"text-gray-600 mt-1\">\n            {user?.shopName || \"未知客户\"} · {categoryLabels[product.category] || product.category} ·{\" \"}\n            <span className={statusColors[product.status]}>\n              {statusLabels[product.status] || product.status}\n            </span>\n          </p>\n        </div>\n\n        {/* Deliver Button */}\n        {canDeliver && product.status === \"reviewing\" && (\n          <div className=\"flex gap-2\">\n            <ReviewActions\n              productId={product.id}\n              productStatus={product.status}\n              approvedCount={approvedImages.length}\n              deliveryCount={product.deliveryCount}\n            />\n          </div>\n        )}\n      </div>\n\n      {/* Stats */}\n      <div className=\"grid grid-cols-2 md:grid-cols-4 gap-4\">\n        <div className=\"bg-white p-4 rounded-lg shadow-sm border\">\n          <p className=\"text-sm text-gray-500\">待审核</p>\n          <p className=\"text-2xl font-bold text-yellow-600\">{pendingImages.length}</p>\n        </div>\n        <div className=\"bg-white p-4 rounded-lg shadow-sm border\">\n          <p className=\"text-sm text-gray-500\">已通过</p>\n          <p className=\"text-2xl font-bold text-green-600\">{approvedImages.length}</p>\n        </div>\n        <div className=\"bg-white p-4 rounded-lg shadow-sm border\">\n          <p className=\"text-sm text-gray-500\">已淘汰</p>\n          <p className=\"text-2xl font-bold text-red-600\">{rejectedImages.length}</p>\n        </div>\n        <div className=\"bg-white p-4 rounded-lg shadow-sm border\">\n          <p className=\"text-sm text-gray-500\">需重新生成</p>\n          <p className=\"text-2xl font-bold text-orange-600\">{regenerateImages.length}</p>\n        </div>\n      </div>\n\n      {/* Product Info */}\n      <div className=\"bg-white rounded-xl p-6 shadow-sm\">\n        <h2 className=\"text-lg font-semibold text-[#4E342E] mb-4\">产品信息</h2>\n        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4 text-sm\">\n          <div>\n            <span className=\"text-gray-500\">拍摄需求</span>\n            <p className=\"text-[#4E342E]\">{product.shootingRequirements}</p>\n          </div>\n          {product.specialNotes && (\n            <div>\n              <span className=\"text-gray-500\">特别注意事项</span>\n              <p className=\"text-[#4E342E]\">{product.specialNotes}</p>\n            </div>\n          )}\n          <div>\n            <span className=\"text-gray-500\">期望交付</span>\n            <p className=\"text-[#4E342E]\">{product.deliveryCount} 张 (当前通过: {approvedImages.length})</p>\n          </div>\n        </div>\n      </div>\n\n      {/* Source Images */}\n      {sourceImages.length > 0 && (\n        <div className=\"bg-white rounded-xl p-6 shadow-sm\">\n          <h2 className=\"text-lg font-semibold text-[#4E342E] mb-4\">\n            原始图片 ({sourceImages.length})\n          </h2>\n          <div className=\"grid grid-cols-2 md:grid-cols-4 gap-4\">\n            {sourceImages.map((img) => (\n              <div\n                key={img.id}\n                className=\"aspect-square relative rounded-lg overflow-hidden bg-gray-100\"\n              >\n                <Image\n                  src={img.url}\n                  alt={img.fileName}\n                  fill\n                  className=\"object-cover\"\n                />\n              </div>\n            ))}\n          </div>\n        </div>\n      )}\n\n      {/* Generated Images */}\n      <div className=\"bg-white rounded-xl p-6 shadow-sm\">\n        <div className=\"flex items-center justify-between mb-4\">\n          <h2 className=\"text-lg font-semibold text-[#4E342E]\">\n            AI 生成图片 ({generatedImages.length})\n          </h2>\n          <div className=\"text-sm text-gray-500\">\n            {canDeliver ? (\n              <span className=\"text-green-600 font-medium\">✓ 已达到交付标准</span>\n            ) : (\n              <span>还需 {product.deliveryCount - approvedImages.length} 张通过</span>\n            )}\n          </div>\n        </div>\n\n        {generatedImages.length === 0 ? (\n          <div className=\"text-center py-12\">\n            <div className=\"text-4xl mb-3\">🖼️</div>\n            <p className=\"text-gray-500\">\n              {product.status === \"processing\"\n                ? \"AI 正在生成中，请稍候...\"\n                : product.status === \"queued\"\n                ? \"等待 AI 处理...\"\n                : \"暂无生成图片\"}\n            </p>\n          </div>\n        ) : (\n          <div className=\"grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4\">\n            {generatedImages.map((img) => (\n              <div\n                key={img.id}\n                className={`relative aspect-[3/4] rounded-lg overflow-hidden bg-gray-100 group ${\n                  img.reviewStatus === \"approved\"\n                    ? \"ring-2 ring-green-500\"\n                    : img.reviewStatus === \"rejected\"\n                    ? \"opacity-60\"\n                    : \"\"\n                }`}\n              >\n                <Image\n                  src={img.url}\n                  alt=\"Generated\"\n                  fill\n                  className=\"object-cover\"\n                />\n\n                {/* Status Badge */}\n                <div className=\"absolute top-2 left-2\">\n                  <span\n                    className={`px-2 py-1 rounded-full text-xs font-medium ${\n                      reviewStatusColors[img.reviewStatus]\n                    }`}\n                  >\n                    {reviewStatusLabels[img.reviewStatus]}\n                  </span>\n                </div>\n\n                {/* Batch Number */}\n                <div className=\"absolute top-2 right-2\">\n                  <span className=\"px-2 py-1 bg-black/50 text-white text-xs rounded-full\">\n                    第 {img.batchNumber} 批\n                  </span>\n                </div>\n\n                {/* Actions - Only show for pending images when status allows */}\n                {isEditable && img.reviewStatus === \"pending\" && (\n                  <div className=\"absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center gap-2\">\n                    <button\n                      onClick={`approveImage('${img.id}')`}\n                      className=\"px-3 py-1.5 bg-green-500 text-white text-sm rounded-lg hover:bg-green-600\"\n                    >\n                      ✓ 通过\n                    </button>\n                    <button\n                      onClick={`rejectImage('${img.id}')`}\n                      className=\"px-3 py-1.5 bg-red-500 text-white text-sm rounded-lg hover:bg-red-600\"\n                    >\n                      ✗ 淘汰\n                    </button>\n                  </div>\n                )}\n              </div>\n            ))}\n          </div>\n        )}\n\n        {/* Quick Actions */}\n        {isEditable && pendingImages.length > 0 && (\n          <div className=\"mt-6 pt-6 border-t flex flex-wrap gap-2\">\n            <button\n              onClick=\"approveAllPending()\"\n              className=\"px-4 py-2 bg-green-500 text-white rounded-lg hover:bg-green-600\"\n            >\n              全部通过 ({pendingImages.length})\n            </button>\n            <button\n              onClick=\"rejectAllPending()\"\n              className=\"px-4 py-2 bg-red-500 text-white rounded-lg hover:bg-red-600\"\n            >\n              全部淘汰\n            </button>\n            <button\n              onClick=\"regenerateAllPending()\"\n              className=\"px-4 py-2 bg-orange-500 text-white rounded-lg hover:bg-orange-600\"\n            >\n              全部重新生成\n            </button>\n          </div>\n        )}\n      </div>\n    </div>\n  );\n}\n"}}],"model":"MiniMax-M2.5","stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":144,"output_tokens":0,"cache_creation_input_tokens":2425,"cache_read_input_tokens":63276},"service_tier":"standard","context_management":null},"parent_tool_use_id":null,"session_id":"0fe3e04a-e649-4c3b-ad04-3a2fa78bad13","uuid":"ba261716-8ea7-421a-be40-311c11c06aa2"}
