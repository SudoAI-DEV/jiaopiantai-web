/* Product Info */}\n   108→      <div className=\"bg-white rounded-xl p-6 shadow-sm\">\n   109→        <h2 className=\"text-lg font-semibold text-[#4E342E] mb-4\">\n   110→          产品信息\n   111→        </h2>\n   112→        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4 text-sm\">\n   113→          <div>\n   114→            <span className=\"text-gray-500\">产品名称</span>\n   115→            <p className=\"text-[#4E342E]\">{product.name}</p>\n   116→          </div>\n   117→          <div>\n   118→            <span className=\"text-gray-500\">产品类目</span>\n   119→            <p className=\"text-[#4E342E]\">\n   120→              {categoryLabels[product.category] || product.category}\n   121→            </p>\n   122→          </div>\n   123→          {product.description && (\n   124→            <div className=\"md:col-span-2\">\n   125→              <span className=\"text-gray-500\">产品描述</span>\n   126→              <p className=\"text-[#4E342E]\">{product.description}</p>\n   127→            </div>\n   128→          )}\n   129→          <div className=\"md:col-span-2\">\n   130→            <span className=\"text-gray-500\">拍摄需求</span>\n   131→            <p className=\"text-[#4E342E]\">{product.shootingRequirements}</p>\n   132→          </div>\n   133→          {product.specialNotes && (\n   134→            <div className=\"md:col-span-2\">\n   135→              <span className=\"text-gray-500\">特别注意事项</span>\n   136→              <p className=\"text-[#4E342E]\">{product.specialNotes}</p>\n   137→            </div>\n   138→          )}\n   139→          <div>\n   140→            <span className=\"text-gray-500\">期望交付</span>\n   141→            <p className=\"text-[#4E342E]\">{product.deliveryCount} 张</p>\n   142→          </div>\n   143→        </div>\n   144→      </div>\n   145→\n   146→      {/* Source Images */}\n   147→      <div className=\"bg-white rounded-xl p-6 shadow-sm\">\n   148→        <h2 className=\"text-lg font-semibold text-[#4E342E] mb-4\">