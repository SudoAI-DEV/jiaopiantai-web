: 'timestamp' }),\n    38→  scope: text('scope'),\n    39→  password: text('password'),\n    40→  createdAt: integer('created_at', { mode: 'timestamp' }).notNull(),\n    41→  updatedAt: integer('updated_at', { mode: 'timestamp' }).notNull(),\n    42→});\n    43→\n    44→// 验证表\n    45→export const verifications = sqliteTable('verifications', {\n    46→  id: text('id').primaryKey(),\n    47→  identifier: text('identifier').notNull(),\n    48→  value: text('value').notNull(),\n    49→  expiresAt: integer('expires_at', { mode: 'timestamp' }).notNull(),\n    50→  createdAt: integer('created_at', { mode: 'timestamp' }),\n    51→  updatedAt: integer('updated_at', { mode: 'timestamp' }),\n    52→});\n    53→\n    54→// 扩展用户表 - 应用特定字段\n    55→export const userProfiles = sqliteTable('user_profiles', {\n    56→  id: text('id').primaryKey().references(() => users.id, { onDelete: 'cascade' }),\n    57→  role: text('role', { enum: ['customer', 'admin'] }).default('customer').notNull(),\n    58→  shopName: text('shop_name'),\n    59→  phone: text('phone'),\n    60→  category: text('category'),\n    61→  creditsBalance: integer('credits_balance').default(0).notNull(),\n    62→  creditsFrozen: integer('credits_frozen').default(0).notNull(),\n    63→  creditsTotalSpent: integer('credits_total_spent').default(0).notNull(),\n    64→});\n    65→\n    66→// 角色枚举\n    67→export const roleEnum = ['customer', 'admin'] as const;\n    68→export type Role = typeof roleEnum[number];\n    69→\n    70→// 产品状态枚举\n    71→export const productStatusEnum = ['draft', 'submitted', 'queued', 'processing', 'reviewing', 'client_reviewing', 'feedback_received', 'reworking', 'completed', 'failed', 'cancelled'] as const;\n    72→export type ProductStatus = typeof productStatusEnum[number];\n    73→\n    74→// 图片审核状态枚举\n    75→export const imageReviewStatusEnum = ['pending', 'approved', 'rejected', 'regenerate'] as const;\n    76→export type ImageReviewStatus = typeof imageReviewStatusEnum[number];\n    77→\n    78→// 交易类型枚举\n    79→export const transactionTypeEnum = ['recharge', 'purchase', 'submission', 'completion', 'refund'] as const;\n    80→export type TransactionType = typeof transactionTypeEnum[number];\n    81→\n    82→// 反馈类型枚举\n    83→export const feedbackTypeEnum = ['perfect', 'minor_issues', 'major_issues', 'other'] as const;\n    84→export type FeedbackType = typeof feedbackTypeEnum[number];\n    85→\n    86→// 点数交易记录表\n    87→export const creditTransactions = sqliteTable('credit_transactions', {\n    88→  id: text('id').primaryKey(),\n    89→  userId: text('user_id').notNull(),\n    90→  type: text('type', { enum: transactionTypeEnum }).notNull(),\n    91→  amount: integer('amount').notNull(),\n    92→  balanceAfter: integer('balance_after').notNull(),\n    93→  productId: text('product_id'),\n    94→  description: text('description'),\n    95→  createdAt: integer('created_at', { mode: 'timestamp' }).notNull(),\n    96→}, (table) => ({\n    97→  userIdIdx: index('ct_user_id_idx').on(table.userId),\n    98→}));\n    99→\n   100→// 产品表\n   101→export const products = sqliteTable('products', {\n   102→  id: text('id').primaryKey(),\n   103→  productNumber: text('product_number').notNull().unique(),\n   104→  userId: text('user_id').notNull(),\n   105→  name: text('name').notNull(),\n   106→  category: text('category').notNull(),\n   107→  description: text('description'),\n   108→  shootingRequirements: text('shooting_requirements').notNull(),\n   109→  stylePreference: text('style_preference').notNull(),\n   110→  specialNotes: text('special_notes'),\n   111→  deliveryCount: integer('delivery_count').default(6).notNull(),\n   112→  status: text('status', { enum: productStatusEnum }).default('draft').notNull(),\n   113→  createdAt: integer('created_at', { mode: 'timestamp' }).notNull(),\n   114→  updatedAt: integer('created_at', { mode: 'timestamp' }).notNull(),\n   115→}, (table) => ({\n   116→  userIdIdx: index('product_user_id_idx').on(table.userId),\n   117→  productNumberIdx: index('product_number_idx').on(table.productNumber),\n   118→}));\n   119→\n   120→// 产品原始图片表\n   121→export const productSourceImages = sqliteTable('product_source_images', {\n   122→  id: text('id').primaryKey(),\n   123→  productId: text('product_id').notNull(),\n   124→  url: text('url').notNull(),\n   125→  fileName: text('file_name').notNull(),\n   126→  fileSize: integer('file_size'),\n   127→  mimeType: text('mime_type'),\n   128→  sortOrder: integer('sort_order').default(0),\n   129→  createdAt: integer('created_at', { mode: 'timestamp' }).notNull(),\n   130→}, (table) => ({\n   131→  productIdIdx: index('source_image_product_idx').on(table.productId),\n   132→}));\n   133→\n   134→// AI 生成图片表\n   135→export const productGeneratedImages = sqliteTable('product_generated_images', {\n   136→  id: text('id').primaryKey(),\n   137→  productId: text('product_id').notNull(),\n   138→  url: text('url').notNull(),\n   139→  thumbnailUrl: text('thumbnail_url'),\n   140→  batchNumber: integer('batch_number').default(1).notNull(),\n   141→  reviewStatus: text('review_status', { enum: imageReviewStatusEnum }).default('pending').notNull(),\n   142→  sortOrder: integer('sort_order').default(0),\n   143→  createdAt: integer('created_at', { mode: 'timestamp' }).notNull(),\n   144→  reviewedAt: integer('reviewed_at', { mode: 'timestamp' }),\n   145→  reviewedBy: text('reviewed_by'),\n   146→}, (table) => ({\n   147→  productIdIdx: index('generated_image_product_idx').on(table.productId),\n   148→}));\n   149→\n   150→// 图片反馈表\n   151→export const imageFeedbacks = sqliteTable('image_feedbacks', {\n   152→  id: text('id').primaryKey(),\n   153→  productId: text('product_id').notNull(),\n   154→  userId: text('user_id').notNull(),\n   155→  type: text('type', { enum: feedbackTypeEnum }).notNull(),\n   156→  description: text('description'),\n   157→  createdAt: integer('created_at', { mode: 'timestamp' }).notNull(),\n   158→});\n   159→\n   160→// 风格模板表\n   161→export const styleTemplates = sqliteTable('style_templates', {\n   162→  id: text('id').primaryKey(),\n   163→  name: text('name').notNull(),\n   164→  description: text('description'),\n   165→  thumbnailUrl: text('thumbnail_url'),\n   166→  isActive: integer('is_active', { mode: 'boolean' }).default(true).notNull(),\n   167→  sortOrder: integer('sort_order').default(0),\n   168→  createdAt: integer('created_at', { mode: 'timestamp' }).notNull(),\n   169→});\n   170→\n   171→// 产品风格选择表\n   172→export const productStyleSelections = sqliteTable('product_style_selections', {\n   173→  id: text('id').primaryKey(),\n   174→  productId: text('product_id').notNull(),\n   175→  styleId: text('style_id').notNull(),\n   176→  createdAt: integer('created_at', { mode: 'timestamp' }).notNull(),\n   177→});\n   178→\n   179→// 交付批次表\n   180→export const deliveryBatches = sqliteTable('delivery_batches', {\n   181→  id: text('id').primaryKey(),\n   182→  productId: text('product_id').notNull(),\n   183→  batchNumber: integer('batch_number').notNull(),\n   184→  imageCount: integer('image_count').notNull(),\n   185→  deliveredAt: integer('delivered_at', { mode: 'timestamp' }).notNull(),\n   186→  deliveredBy: text('delivered_by'),\n   187→});\n   188→\n   189→// 交付图片明细表\n   190→export const deliveryImages = sqliteTable('delivery_images', {\n   191→  id: text('id').primaryKey(),\n   192→  deliveryBatchId: text('delivery_batch_id').notNull(),\n   193→  imageId: text('image_id').notNull(),\n   194→  sortOrder: integer('sort_order').default(0),\n   195→});\n   196→\n   197→// AI 生成任务表\n   198→export const aiGenerationTasks = sqliteTable('ai_generation_tasks', {\n   199→  id: text('id').primaryKey(),\n   200→  productId: text('product_id').notNull(),\n   201→  batchNumber: integer('batch_number').default(1).notNull(),\n   202→  status: text('status').default('pending').notNull(),\n   203→  targetCount: integer('target_count').default(20).notNull(),\n   204→  resultCount: integer('result_count'),\n   205→  errorMessage: text('error_message'),\n   206→  startedAt: integer('started_at', { mode: 'timestamp' }),\n   207→  completedAt: integer('completed_at', { mode: 'timestamp' }),\n   208→  createdAt: integer('created_at', { mode: 'timestamp' }).notNull(),\n   209→});\n   210→\n   211→// 操作审计日志表\n   212→export const operationLogs = sqliteTable('operation_logs', {\n   213→  id: text('id').primaryKey(),\n   214→  userId: text('user_id'),\n   215→  action: text('action').notNull(),\n   216→  resourceType: text('resource_type').notNull(),\n   217→  resourceId: text('resource_id'),\n   218→  details: text('details'),\n   219→  ipAddress: text('ip_address'),\n   220→  createdAt: integer('created_at', { mode: 'timestamp' }).notNull(),\n   221→});\n   222→\n   223→// 用户关系\n   224→export const usersRelations = relations(users, ({ one, many }) => ({\n   225→  profile: one(userProfiles, {\n   226→    fields: [users.id],\n   227→    references: [userProfiles.id],\n   228→  }),\n   229→  products: many(products),\n   230→  creditTransactions: many(creditTransactions),\n   231→}));\n   232→\n   233→// 用户配置关系\n   234→export const userProfilesRelations = relations(userProfiles, ({ one }) => ({\n   235→  user: one(users, {\n   236→    fields: [userProfiles.id],\n   237→    references: [users.id],\n   238→  }),\n   239→}));\n   240→\n   241→// 产品关系\n   242→export const productsRelations = relations(products, ({ one, many }) => ({\n   243→  user: one(users, {\n   244→    fields: [products.userId],\n   245→    references: [users.id],\n   246→  }),\n   247→  sourceImages: many(productSourceImages),\n   248→  generatedImages: many(productGeneratedImages),\n   249→}));\n   250→\n   251→// 原始图片关系\n   252→export const productSourceImagesRelations = relations(productSourceImages, ({ one }) => ({\n   253→  product: one(products, {\n   254→    fields: [productSourceImages.productId],\n   255→    references: [products.id],\n   256→  }),\n   257→}));\n   258→\n   259→// 生成图片关系\n   260→export const productGeneratedImagesRelations = relations(productGeneratedImages, ({ one }) => ({\n   261→  product: one(products, {\n   262→    fields: [productGeneratedImages.productId],\n   263→    references: [products.id],\n   264→  }),\n   265→}));\n   266→\n   267→// 反馈关系\n   268→export const imageFeedbacksRelations = relations(imageFeedbacks, ({ one }) => ({\n   269→  product: one(products, {\n   270→    fields: [imageFeedbacks.productId],\n   271→    references: [products.id],\n   272→  }),\n   273→  user: one(users, {\n   274→    fields: [imageFeedbacks.userId],\n   275→    references: [users.id],\n   276→  }),\n   277→}));\n   278→\n   279→// 风格选择关系\n   280→export const productStyleSelectionsRelations = relations(productStyleSelections, ({ one }) => ({\n   281→  product: one(products, {\n   282→    fields: [productStyleSelections.productId],\n   283→    references: [products.id],\n   284→  }),\n   285→  style: one(styleTemplates, {\n   286→    fields: [productStyleSelections.styleId],\n   287→    references: [styleTemplates.id],\n   288→  }),\n   289→}));\n   290→\n   291→// 交付批次关系\n   292→export const deliveryBatchesRelations = relations(deliveryBatches, ({ one, many }) => ({\n   293→  product: one(products, {\n   294→    fields: [deliveryBatches.productId],\n   295→    references: [products.id],\n   296→  }),\n   297→  deliveredByUser: one(users, {\n   298→    fields: [deliveryBatches.deliveredBy],\n   299→    references: [users.id],\n   300→  }),\n   301→  images: many(deliveryImages),\n   302→}));\n   303→\n   304→// 交付图片关系\n   305→export const deliveryImagesRelations = relations(deliveryImages, ({ one }) => ({\n   306→  batch: one(deliveryBatches, {\n   307→    fields: [deliveryImages.deliveryBatchId],\n   308→    references: [deliveryBatches.id],\n   309→  }),\n   310→  image: one(productGeneratedImages, {\n   311→    fields: [deliveryImages.imageId],\n   312→    references: [productGeneratedImages.id],\n   313→  }),\n   314→}));\n   315→\n   316→// 任务关系\n   317→export const aiGenerationTasksRelations = relations(aiGenerationTasks, ({ one }) => ({\n   318→  product: one(products, {\n   319→    fields: [aiGenerationTasks.productId],\n   320→    references: [products.id],\n   321→  }),\n   322→}));\n   323→\n   324→// 审计日志关系\n   325→export const operationLogsRelations = relations(operationLogs, ({ one }) => ({\n   326→  user: one(users, {\n   327→    fields: [operationLogs.userId],\n   328→    references: [users.id],\n   329→  }),\n   330→}));\n   331→\n   332→// 导出类型\n   333→export type User = typeof users.$inferSelect;\n   334→export type NewUser = typeof users.$inferInsert;\n   335→export type Product = typeof products.$inferSelect;\n   336→export type NewProduct = typeof products.$inferInsert;\n   337→export type ProductSourceImage = typeof productSourceImages.$inferSelect;\n   338→export type ProductGeneratedImage = typeof productGeneratedImages.$inferSelect;\n   339→export type CreditTransaction = typeof creditTransactions.$inferSelect;\n   340→export type StyleTemplate = typeof styleTemplates.$inferSelect;\n   341→export type DeliveryBatch = typeof deliveryBatches.$inferSelect;\n   342→export type AIGenerationTask = typeof aiGenerationTasks.$inferSelect;\n   343→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"0fe3e04a-e649-4c3b-ad04-3a2fa78bad13","uuid":"a663a4f1-eaf4-4091-965f-5cc9523f53db","tool_use_result":{"type":"text","file":{"filePath":"/Users/yepingzheng/SudoAI/jiaopiantai/src/lib/db/schema.ts","content":"import { sqliteTable, text, integer, real, primaryKey, index } from 'drizzle-orm/sqlite-core';\nimport { relations } from 'drizzle-orm';\n\n// 用户表 - Better Auth 兼容\nexport const users = sqliteTable('users', {\n  id: text('id').primaryKey(),\n  name: text('name').notNull(),\n  email: text('email').notNull().unique(),\n  emailVerified: integer('email_verified', { mode: 'boolean' }).default(false),\n  image: text('image'),\n  createdAt: integer('created_at', { mode: 'timestamp' }).notNull(),\n  updatedAt: integer('updated_at', { mode: 'timestamp' }).notNull(),\n});\n\n// 会话表\nexport const sessions = sqliteTable('sessions', {\n  id: text('id').primaryKey(),\n  expiresAt: integer('expires_at', { mode: 'timestamp' }).notNull(),\n  token: text('token').notNull().unique(),\n  createdAt: integer('created_at', { mode: 'timestamp' }).notNull(),\n  updatedAt: integer('updated_at', { mode: 'timestamp' }).notNull(),\n  ipAddress: text('ip_address'),\n  userAgent: text('user_agent'),\n  userId: text('user_id').notNull().references(() => users.id, { onDelete: 'cascade' }),\n});\n\n// 账户表\nexport const accounts = sqliteTable('accounts', {\n  id: text('id').primaryKey(),\n  accountId: text('account_id').notNull(),\n  providerId: text('provider_id').notNull(),\n  userId: text('user_id').notNull().references(() => users.id, { onDelete: 'cascade' }),\n  accessToken: text('access_token'),\n  refreshToken: text('refresh_token'),\n  idToken: text('id_token'),\n  accessTokenExpiresAt: integer('access_token_expires_at', { mode: 'timestamp' }),\n  refreshTokenExpiresAt: integer('refresh_token_expires_at', { mode: 'timestamp' }),\n  scope: text('scope'),\n  password: text('password'),\n  createdAt: integer('created_at', { mode: 'timestamp' }).notNull(),\n  updatedAt: integer('updated_at', { mode: 'timestamp' }).notNull(),\n});\n\n// 验证表\nexport const verifications = sqliteTable('verifications', {\n  id: text('id').primaryKey(),\n  identifier: text('identifier').notNull(),\n  value: text('value').notNull(),\n  expiresAt: integer('expires_at', { mode: 'timestamp' }).notNull(),\n  createdAt: integer('created_at', { mode: 'timestamp' }),\n  updatedAt: integer('updated_at', { mode: 'timestamp' }),\n});\n\n// 扩展用户表 - 应用特定字段\nexport const userProfiles = sqliteTable('user_profiles', {\n  id: text('id').primaryKey().references(() => users.id, { onDelete: 'cascade' }),\n  role: text('role', { enum: ['customer', 'admin'] }).default('customer').notNull(),\n  shopName: text('shop_name'),\n  phone: text('phone'),\n  category: text('category'),\n  creditsBalance: integer('credits_balance').default(0).notNull(),\n  creditsFrozen: integer('credits_frozen').default(0).notNull(),\n  creditsTotalSpent: integer('credits_total_spent').default(0).notNull(),\n});\n\n// 角色枚举\nexport const roleEnum = ['customer', 'admin'] as const;\nexport type Role = typeof roleEnum[number];\n\n// 产品状态枚举\nexport const productStatusEnum = ['draft', 'submitted', 'queued', 'processing', 'reviewing', 'client_reviewing', 'feedback_received', 'reworking', 'completed', 'failed', 'cancelled'] as const;\nexport type ProductStatus = typeof productStatusEnum[number];\n\n// 图片审核状态枚举\nexport const imageReviewStatusEnum = ['pending', 'approved', 'rejected', 'regenerate'] as const;\nexport type ImageReviewStatus = typeof imageReviewStatusEnum[number];\n\n// 交易类型枚举\nexport const transactionTypeEnum = ['recharge', 'purchase', 'submission', 'completion', 'refund'] as const;\nexport type TransactionType = typeof transactionTypeEnum[number];\n\n// 反馈类型枚举\nexport const feedbackTypeEnum = ['perfect', 'minor_issues', 'major_issues', 'other'] as const;\nexport type FeedbackType = typeof feedbackTypeEnum[number];\n\n// 点数交易记录表\nexport const creditTransactions = sqliteTable('credit_transactions', {\n  id: text('id').primaryKey(),\n  userId: text('user_id').notNull(),\n  type: text('type', { enum: transactionTypeEnum }).notNull(),\n  amount: integer('amount').notNull(),\n  balanceAfter: integer('balance_after').notNull(),\n  productId: text('product_id'),\n  description: text('description'),\n  createdAt: integer('created_at', { mode: 'timestamp' }).notNull(),\n}, (table) => ({\n  userIdIdx: index('ct_user_id_idx').on(table.userId),\n}));\n\n// 产品表\nexport const products = sqliteTable('products', {\n  id: text('id').primaryKey(),\n  productNumber: text('product_number').notNull().unique(),\n  userId: text('user_id').notNull(),\n  name: text('name').notNull(),\n  category: text('category').notNull(),\n  description: text('description'),\n  shootingRequirements: text('shooting_requirements').notNull(),\n  stylePreference: text('style_preference').notNull(),\n  specialNotes: text('special_notes'),\n  deliveryCount: integer('delivery_count').default(6).notNull(),\n  status: text('status', { enum: productStatusEnum }).default('draft').notNull(),\n  createdAt: integer('created_at', { mode: 'timestamp' }).notNull(),\n  updatedAt: integer('created_at', { mode: 'timestamp' }).notNull(),\n}, (table) => ({\n  userIdIdx: index('product_user_id_idx').on(table.userId),\n  productNumberIdx: index('product_number_idx').on(table.productNumber),\n}));\n\n// 产品原始图片表\nexport const productSourceImages = sqliteTable('product_source_images', {\n  id: text('id').primaryKey(),\n  productId: text('product_id').notNull(),\n  url: text('url').notNull(),\n  fileName: text('file_name').notNull(),\n  fileSize: integer('file_size'),\n  mimeType: text('mime_type'),\n  sortOrder: integer('sort_order').default(0),\n  createdAt: integer('created_at', { mode: 'timestamp' }).notNull(),\n}, (table) => ({\n  productIdIdx: index('source_image_product_idx').on(table.productId),\n}));\n\n// AI 生成图片表\nexport const productGeneratedImages = sqliteTable('product_generated_images', {\n  id: text('id').primaryKey(),\n  productId: text('product_id').notNull(),\n  url: text('url').notNull(),\n  thumbnailUrl: text('thumbnail_url'),\n  batchNumber: integer('batch_number').default(1).notNull(),\n  reviewStatus: text('review_status', { enum: imageReviewStatusEnum }).default('pending').notNull(),\n  sortOrder: integer('sort_order').default(0),\n  createdAt: integer('created_at', { mode: 'timestamp' }).notNull(),\n  reviewedAt: integer('reviewed_at', { mode: 'timestamp' }),\n  reviewedBy: text('reviewed_by'),\n}, (table) => ({\n  productIdIdx: index('generated_image_product_idx').on(table.productId),\n}));\n\n// 图片反馈表\nexport const imageFeedbacks = sqliteTable('image_feedbacks', {\n  id: text('id').primaryKey(),\n  productId: text('product_id').notNull(),\n  userId: text('user_id').notNull(),\n  type: text('type', { enum: feedbackTypeEnum }).notNull(),\n  description: text('description'),\n  createdAt: integer('created_at', { mode: 'timestamp' }).notNull(),\n});\n\n// 风格模板表\nexport const styleTemplates = sqliteTable('style_templates', {\n  id: text('id').primaryKey(),\n  name: text('name').notNull(),\n  description: text('description'),\n  thumbnailUrl: text('thumbnail_url'),\n  isActive: integer('is_active', { mode: 'boolean' }).default(true).notNull(),\n  sortOrder: integer('sort_order').default(0),\n  createdAt: integer('created_at', { mode: 'timestamp' }).notNull(),\n});\n\n// 产品风格选择表\nexport const productStyleSelections = sqliteTable('product_style_selections', {\n  id: text('id').primaryKey(),\n  productId: text('product_id').notNull(),\n  styleId: text('style_id').notNull(),\n  createdAt: integer('created_at', { mode: 'timestamp' }).notNull(),\n});\n\n// 交付批次表\nexport const deliveryBatches = sqliteTable('delivery_batches', {\n  id: text('id').primaryKey(),\n  productId: text('product_id').notNull(),\n  batchNumber: integer('batch_number').notNull(),\n  imageCount: integer('image_count').notNull(),\n  deliveredAt: integer('delivered_at', { mode: 'timestamp' }).notNull(),\n  deliveredBy: text('delivered_by'),\n});\n\n// 交付图片明细表\nexport const deliveryImages = sqliteTable('delivery_images', {\n  id: text('id').primaryKey(),\n  deliveryBatchId: text('delivery_batch_id').notNull(),\n  imageId: text('image_id').notNull(),\n  sortOrder: integer('sort_order').default(0),\n});\n\n// AI 生成任务表\nexport const aiGenerationTasks = sqliteTable('ai_generation_tasks', {\n  id: text('id').primaryKey(),\n  productId: text('product_id').notNull(),\n  batchNumber: integer('batch_number').default(1).notNull(),\n  status: text('status').default('pending').notNull(),\n  targetCount: integer('target_count').default(20).notNull(),\n  resultCount: integer('result_count'),\n  errorMessage: text('error_message'),\n  startedAt: integer('started_at', { mode: 'timestamp' }),\n  completedAt: integer('completed_at', { mode: 'timestamp' }),\n  createdAt: integer('created_at', { mode: 'timestamp' }).notNull(),\n});\n\n// 操作审计日志表\nexport const operationLogs = sqliteTable('operation_logs', {\n  id: text('id').primaryKey(),\n  userId: text('user_id'),\n  action: text('action').notNull(),\n  resourceType: text('resource_type').notNull(),\n  resourceId: text('resource_id'),\n  details: text('details'),\n  ipAddress: text('ip_address'),\n  createdAt: integer('created_at', { mode: 'timestamp' }).notNull(),\n});\n\n// 用户关系\nexport const usersRelations = relations(users, ({ one, many }) => ({\n  profile: one(userProfiles, {\n    fields: [users.id],\n    references: [userProfiles.id],\n  }),\n  products: many(products),\n  creditTransactions: many(creditTransactions),\n}));\n\n// 用户配置关系\nexport const userProfilesRelations = relations(userProfiles, ({ one }) => ({\n  user: one(users, {\n    fields: [userProfiles.id],\n    references: [users.id],\n  }),\n}));\n\n// 产品关系\nexport const productsRelations = relations(products, ({ one, many }) => ({\n  user: one(users, {\n    fields: [products.userId],\n    references: [users.id],\n  }),\n  sourceImages: many(productSourceImages),\n  generatedImages: many(productGeneratedImages),\n}));\n\n// 原始图片关系\nexport const productSourceImagesRelations = relations(productSourceImages, ({ one }) => ({\n  product: one(products, {\n    fields: [productSourceImages.productId],\n    references: [products.id],\n  }),\n}));\n\n// 生成图片关系\nexport const productGeneratedImagesRelations = relations(productGeneratedImages, ({ one }) => ({\n  product: one(products, {\n    fields: [productGeneratedImages.productId],\n    references: [products.id],\n  }),\n}));\n\n// 反馈关系\nexport const imageFeedbacksRelations = relations(imageFeedbacks, ({ one }) => ({\n  product: one(products, {\n    fields: [imageFeedbacks.productId],\n    references: [products.id],\n  }),\n  user: one(users, {\n    fields: [imageFeedbacks.userId],\n    references: [users.id],\n  }),\n}));\n\n// 风格选择关系\nexport const productStyleSelectionsRelations = relations(productStyleSelections, ({ one }) => ({\n  product: one(products, {\n    fields: [productStyleSelections.productId],\n    references: [products.id],\n  }),\n  style: one(styleTemplates, {\n    fields: [productStyleSelections.styleId],\n    references: [styleTemplates.id],\n  }),\n}));\n\n// 交付批次关系\nexport const deliveryBatchesRelations = relations(deliveryBatches, ({ one, many }) => ({\n  product: one(products, {\n    fields: [deliveryBatches.productId],\n    references: [products.id],\n  }),\n  deliveredByUser: one(users, {\n    fields: [deliveryBatches.deliveredBy],\n    references: [users.id],\n  }),\n  images: many(deliveryImages),\n}));\n\n// 交付图片关系\nexport const deliveryImagesRelations = relations(deliveryImages, ({ one }) => ({\n  batch: one(deliveryBatches, {\n    fields: [deliveryImages.deliveryBatchId],\n    references: [deliveryBatches.id],\n  }),\n  image: one(productGeneratedImages, {\n    fields: [deliveryImages.imageId],\n    references: [productGeneratedImages.id],\n  }),\n}));\n\n// 任务关系\nexport const aiGenerationTasksRelations = relations(aiGenerationTasks, ({ one }) => ({\n  product: one(products, {\n    fields: [aiGenerationTasks.productId],\n    references: [products.id],\n  }),\n}));\n\n// 审计日志关系\nexport const operationLogsRelations = relations(operationLogs, ({ one }) => ({\n  user: one(users, {\n    fields: [operationLogs.userId],\n    references: [users.id],\n  }),\n}));\n\n// 导出类型\nexport type User = typeof users.$inferSelect;\nexport type NewUser = typeof users.$inferInsert;\nexport type Product = typeof products.$inferSelect;\nexport type NewProduct = typeof products.$inferInsert;\nexport type ProductSourceImage = typeof productSourceImages.$inferSelect;\nexport type ProductGeneratedImage = typeof productGeneratedImages.$inferSelect;\nexport type CreditTransaction = typeof creditTransactions.$inferSelect;\nexport type StyleTemplate = typeof styleTemplates.$inferSelect;\nexport type DeliveryBatch = typeof deliveryBatches.$inferSelect;\nexport type AIGenerationTask = typeof aiGenerationTasks.$inferSelect;\n","numLines":343,"startLine":1,"totalLines":343}}}
