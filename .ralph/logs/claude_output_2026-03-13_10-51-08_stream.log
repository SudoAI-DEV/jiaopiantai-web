{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_33dturcombo2_1","type":"tool_result","content":"     1→\"use client\";\n     2→\n     3→import { useState, useCallback } from \"react\";\n     4→import { useRouter } from \"next/navigation\";\n     5→import { Button } from \"@/components/ui/button\";\n     6→import { Input } from \"@/components/ui/input\";\n     7→import { Label } from \"@/components/ui/label\";\n     8→import Image from \"next/image\";\n     9→\n    10→interface StyleTemplate {\n    11→  id: string;\n    12→  name: string;\n    13→  description: string | null;\n    14→  thumbnailUrl: string | null;\n    15→}\n    16→\n    17→interface NewProductFormProps {\n    18→  categories: { value: string; label: string }[];\n    19→  styleTemplates: StyleTemplate[];\n    20→  availableCredits: number;\n    21→}\n    22→\n    23→export function NewProductForm({\n    24→  categories,\n    25→  styleTemplates,\n    26→  availableCredits,\n    27→}: NewProductFormProps) {\n    28→  const router = useRouter();\n    29→\n    30→  const [formData, setFormData] = useState({\n    31→    name: \"\",\n    32→    category: \"\",\n    33→    description: \"\",\n    34→    shootingRequirements: \"\",\n    35→    stylePreference: styleTemplates[0]?.id || \"\",\n    36→    specialNotes: \"\",\n    37→    deliveryCount: 6,\n    38→  });\n    39→\n    40→  const [sourceImages, setSourceImages] = useState<\n    41→    { id: string; url: string; file: File }[]\n    42→  >([]);\n    43→  const [uploading, setUploading] = useState(false);\n    44→  const [submitting, setSubmitting] = useState(false);\n    45→  const [error, setError] = useState(\"\");\n    46→\n    47→  const handleChange = (\n    48→    e: React.ChangeEvent<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>\n    49→  ) => {\n    50→    setFormData((prev) => ({\n    51→      ...prev,\n    52→      [e.target.name]: e.target.value,\n    53→    }));\n    54→  };\n    55→\n    56→  const handleFileSelect = useCallback(\n    57→    async (e: React.ChangeEvent<HTMLInputElement>) => {\n    58→      const files = Array.from(e.target.files || []);\n    59→      if (files.length === 0) return;\n    60→\n    61→      // Validate files\n    62→      const validTypes = [\"image/jpeg\", \"image/png\", \"image/webp\"];\n    63→      const invalidFiles = files.filter((f) => !validTypes.includes(f.type));\n    64→      if (invalidFiles.length > 0) {\n    65→        setError(\"仅支持 JPG、PNG、WEBP 格式\");\n    66→        return;\n    67→      }\n    68→\n    69→      setUploading(true);\n    70→      setError(\"\");\n    71→\n    72→      try {\n    73→        // Get presigned URLs for each file\n    74→        const imageData = await Promise.all(\n    75→          files.map(async (file) => {\n    76→            const res = await fetch(\"/api/upload/presigned-url\", {\n    77→              method: \"POST\",\n    78→              headers: { \"Content-Type\": \"application/json\" },\n    79→              body: JSON.stringify({\n    80→                fileName: file.name,\n    81→                fileType: file.type,\n    82→              }),\n    83→            });\n    84→\n    85→            if (!res.ok) throw new Error(\"Failed to get upload URL\");\n    86→\n    87→            const { uploadUrl, fileUrl } = await res.json();\n    88→\n    89→            // Upload to OSS\n    90→            await fetch(uploadUrl, {\n    91→              method: \"PUT\",\n    92→              body: file,\n    93→              headers: { \"Content-Type\": file.type },\n    94→            });\n    95→\n    96→            return {\n    97→              id: crypto.randomUUID(),\n    98→              url: fileUrl,\n    99→              file,\n   100→            };\n   101→          })\n   102→        );\n   103→\n   104→        setSourceImages((prev) => [...prev, ...imageData]);\n   105→      } catch (err) {\n   106→        setError(\"图片上传失败，请重试\");\n   107→        console.error(err);\n   108→      } finally {\n   109→        setUploading(false);\n   110→      }\n   111→    },\n   112→    []\n   113→  );\n   114→\n   115→  const removeImage = (id: string) => {\n   116→    setSourceImages((prev) => prev.filter((img) => img.id !== id));\n   117→  };\n   118→\n   119→  const handleSubmit = async (e: React.FormEvent) => {\n   120→    e.preventDefault();\n   121→    setError(\"\");\n   122→\n   123→    if (!formData.name || !formData.category || !formData.shootingRequirements) {\n   124→      setError(\"请填写所有必填字段\");\n   125→      return;\n   126→    }\n   127→\n   128→    if (sourceImages.length === 0) {\n   129→      setError(\"请至少上传一张产品图片\");\n   130→      return;\n   131→    }\n   132→\n   133→    setSubmitting(true);\n   134→\n   135→    try {\n   136→      // Create product\n   137→      const res = await fetch(\"/api/products\", {\n   138→        method: \"POST\",\n   139→        headers: { \"Content-Type\": \"application/json\" },\n   140→        body: JSON.stringify({\n   141→          ...formData,\n   142→          deliveryCount: parseInt(String(formData.deliveryCount)),\n   143→        }),\n   144→      });\n   145→\n   146→      if (!res.ok) {\n   147→        const data = await res.json();\n   148→        throw new Error(data.error || \"创建产品失败\");\n   149→      }\n   150→\n   151→      const { product } = await res.json();\n   152→\n   153→      // Upload source images metadata\n   154→      await Promise.all(\n   155→        sourceImages.map((img, index) =>\n   156→          fetch(\"/api/products/images\", {\n   157→            method: \"POST\",\n   158→            headers: { \"Content-Type\": \"application/json\" },\n   159→            body: JSON.stringify({\n   160→              productId: product.id,\n   161→              url: img.url,\n   162→              fileName: img.file.name,\n   163→              fileSize: img.file.size,\n   164→              mimeType: img.file.type,\n   165→              sortOrder: index,\n   166→            }),\n   167→          })\n   168→        )\n   169→      );\n   170→\n   171→      router.push(`/products/${product.id}`);\n   172→    } catch (err) {\n   173→      setError(err instanceof Error ? err.message : \"创建产品失败\");\n   174→    } finally {\n   175→      setSubmitting(false);\n   176→    }\n   177→  };\n   178→\n   179→  return (\n   180→    <form onSubmit={handleSubmit} className=\"space-y-6\">\n   181→      {error && (\n   182→        <div className=\"p-4 bg-red-50 text-red-600 rounded-lg\">{error}</div>\n   183→      )}\n   184→\n   185→      {/* Basic Info */}\n   186→      <div className=\"bg-white rounded-xl p-6 shadow-sm space-y-4\">\n   187→        <h2 className=\"text-lg font-semibold text-[#4E342E]\">基本信息</h2>\n   188→\n   189→        <div>\n   190→          <Label htmlFor=\"name\">产品名称 *</Label>\n   191→          <Input\n   192→            id=\"name\"\n   193→            name=\"name\"\n   194→            value={formData.name}\n   195→            onChange={handleChange}\n   196→            placeholder=\"例如：2024春季新款连衣裙\"\n   197→            required\n   198→            className=\"mt-1\"\n   199→          />\n   200→        </div>\n   201→\n   202→        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n   203→          <div>\n   204→            <Label htmlFor=\"category\">产品类目 *</Label>\n   205→            <select\n   206→              id=\"category\"\n   207→              name=\"category\"\n   208→              value={formData.category}\n   209→              onChange={handleChange}\n   210→              required\n   211→              className=\"mt-1 w-full px-3 py-2 border border-gray-300 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-[#FDD835]\"\n   212→            >\n   213→              <option value=\"\">请选择类目</option>\n   214→              {categories.map((cat) => (\n   215→                <option key={cat.value} value={cat.value}>\n   216→                  {cat.label}\n   217→                </option>\n   218→              ))}\n   219→            </select>\n   220→          </div>\n   221→\n   222→          <div>\n   223→            <Label htmlFor=\"deliveryCount\">期望交付数量</Label>\n   224→            <Input\n   225→              id=\"deliveryCount\"\n   226→              name=\"deliveryCount\"\n   227→              type=\"number\"\n   228→              min={1}\n   229→              max={20}\n   230→              value={formData.deliveryCount}\n   231→              onChange={handleChange}\n   232→              className=\"mt-1\"\n   233→            />\n   234→          </div>\n   235→        </div>\n   236→\n   237→        <div>\n   238→          <Label htmlFor=\"description\">产品描述</Label>\n   239→          <textarea\n   240→            id=\"description\"\n   241→            name=\"description\"\n   242→            value={formData.description}\n   243→            onChange={handleChange}\n   244→            placeholder=\"补充产品特点、材质等信息（选填）\"\n   245→            rows={3}\n   246→            className=\"mt-1 w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#FDD835]\"\n   247→          />\n   248→        </div>\n   249→      </div>\n   250→\n   251→      {/* Source Images */}\n   252→      <div className=\"bg-white rounded-xl p-6 shadow-sm space-y-4\">\n   253→        <h2 className=\"text-lg font-semibold text-[#4E342E]\">产品图片</h2>\n   254→        <p className=\"text-sm text-gray-500\">\n   255→          上传产品原图，AI 将基于这些图片生成商品图\n   256→        </p>\n   257→\n   258→        <div className=\"grid grid-cols-2 md:grid-cols-4 gap-4\">\n   259→          {sourceImages.map((img) => (\n   260→            <div key={img.id} className=\"relative aspect-square rounded-lg overflow-hidden bg-gray-100\">\n   261→              <Image\n   262→                src={img.url}\n   263→                alt=\"Product image\"\n   264→                fill\n   265→                className=\"object-cover\"\n   266→              />\n   267→              <button\n   268→                type=\"button\"\n   269→                onClick={() => removeImage(img.id)}\n   270→                className=\"absolute top-1 right-1 w-6 h-6 bg-black/50 text-white rounded-full text-sm hover:bg-black/70\"\n   271→              >\n   272→                ×\n   273→              </button>\n   274→            </div>\n   275→          ))}\n   276→\n   277→          <label className=\"aspect-square rounded-lg border-2 border-dashed border-gray-300 flex flex-col items-center justify-center cursor-pointer hover:border-[#FDD835] transition-colors\">\n   278→            <span className=\"text-3xl text-gray-400\">+</span>\n   279→            <span className=\"text-sm text-gray-500 mt-1\">上传图片</span>\n   280→            <input\n   281→              type=\"file\"\n   282→              accept=\"image/jpeg,image/png,image/webp\"\n   283→              multiple\n   284→              onChange={handleFileSelect}\n   285→              className=\"hidden\"\n   286→              disabled={uploading}\n   287→            />\n   288→          </label>\n   289→        </div>\n   290→\n   291→        {uploading && (\n   292→          <p className=\"text-sm text-gray-500\">上传中...</p>\n   293→        )}\n   294→      </div>\n   295→\n   296→      {/* Requirements */}\n   297→      <div className=\"bg-white rounded-xl p-6 shadow-sm space-y-4\">\n   298→        <h2 className=\"text-lg font-semibold text-[#4E342E]\">拍摄需求</h2>\n   299→\n   300→        <div>\n   301→          <Label htmlFor=\"shootingRequirements\">详细需求 *</Label>\n   302→          <textarea\n   303→            id=\"shootingRequirements\"\n   304→            name=\"shootingRequirements\"\n   305→            value={formData.shootingRequirements}\n   306→            onChange={handleChange}\n   307→            placeholder=\"请详细描述您的拍摄需求，如：场景、角度、光线、背景等\"\n   308→            rows={4}\n   309→            required\n   310→            className=\"mt-1 w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#FDD835]\"\n   311→          />\n   312→        </div>\n   313→\n   314→        <div>\n   315→          <Label>选择风格</Label>\n   316→          <div className=\"grid grid-cols-2 md:grid-cols-3 gap-3 mt-2\">\n   317→            {styleTemplates.map((style) => (\n   318→              <label\n   319→                key={style.id}\n   320→                className={`relative rounded-lg border-2 cursor-pointer overflow-hidden transition-colors ${\n   321→                  formData.stylePreference === style.id\n   322→                    ? \"border-[#FDD335] ring-2 ring-[#FDD335]/30\"\n   323→                    : \"border-gray-200 hover:border-gray-300\"\n   324→                }`}\n   325→              >\n   326→                <input\n   327→                  type=\"radio\"\n   328→                  name=\"stylePreference\"\n   329→                  value={style.id}\n   330→                  checked={formData.stylePreference === style.id}\n   331→                  onChange={handleChange}\n   332→                  className=\"sr-only\"\n   333→                />\n   334→                <div className=\"aspect-video bg-gray-100 flex items-center justify-center\">\n   335→                  {style.thumbnailUrl ? (\n   336→                    <Image\n   337→                      src={style.thumbnailUrl}\n   338→                      alt={style.name}\n   339→                      fill\n   340→                      className=\"object-cover\"\n   341→                    />\n   342→                  ) : (\n   343→                    <span className=\"text-2xl\">🎨</span>\n   344→                  )}\n   345→                </div>\n   346→                <div className=\"p-2 bg-white\">\n   347→                  <p className=\"font-medium text-sm text-[#4E342E]\">\n   348→                    {style.name}\n   349→                  </p>\n   350→                  {style.description && (\n   351→                    <p className=\"text-xs text-gray-500 line-clamp-1\">\n   352→                      {style.description}\n   353→                    </p>\n   354→                  )}\n   355→                </div>\n   356→              </label>\n   357→            ))}\n   358→          </div>\n   359→        </div>\n   360→\n   361→        <div>\n   362→          <Label htmlFor=\"specialNotes\">特别注意事项</Label>\n   363→          <textarea\n   364→            id=\"specialNotes\"\n   365→            name=\"specialNotes\"\n   366→            value={formData.specialNotes}\n   367→            onChange={handleChange}\n   368→            placeholder=\"任何需要特别注意的事项（选填）\"\n   369→            rows={2}\n   370→            className=\"mt-1 w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#FDD835]\"\n   371→          />\n   372→        </div>\n   373→      </div>\n   374→\n   375→      {/* Submit */}\n   376→      <div className=\"flex items-center justify-between bg-gray-50 rounded-xl p-4\">\n   377→        <div>\n   378→          <p className=\"text-sm text-gray-600\">消耗点数</p>\n   379→          <p className=\"text-lg font-semibold text-[#4E342E]\">1 点</p>\n   380→        </div>\n   381→        <div className=\"text-right\">\n   382→          <p className=\"text-sm text-gray-600\">可用点数</p>\n   383→          <p className=\"text-lg font-semibold text-[#4E342E]\">\n   384→            {availableCredits} 点\n   385→          </p>\n   386→        </div>\n   387→      </div>\n   388→\n   389→      <Button\n   390→        type=\"submit\"\n   391→        disabled={submitting || uploading}\n   392→        className=\"w-full py-3 bg-[#FDD835] text-[#4E342E] font-semibold rounded-lg hover:bg-[#FDD835]/90 disabled:opacity-50\"\n   393→      >\n   394→        {submitting ? \"创建中...\" : \"创建产品\"}\n   395→      </Button>\n   396→    </form>\n   397→  );\n   398→}\n   399→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"0fe3e04a-e649-4c3b-ad04-3a2fa78bad13","uuid":"a4f6a9f6-7f4a-483f-97a6-65ce72a56817","tool_use_result":{"type":"text","file":{"filePath":"/Users/yepingzheng/SudoAI/jiaopiantai/src/app/(customer)/products/new/new-product-form.tsx","content":"\"use client\";\n\nimport { useState, useCallback } from \"react\";\nimport { useRouter } from \"next/navigation\";\nimport { Button } from \"@/components/ui/button\";\nimport { Input } from \"@/components/ui/input\";\nimport { Label } from \"@/components/ui/label\";\nimport Image from \"next/image\";\n\ninterface StyleTemplate {\n  id: string;\n  name: string;\n  description: string | null;\n  thumbnailUrl: string | null;\n}\n\ninterface NewProductFormProps {\n  categories: { value: string; label: string }[];\n  styleTemplates: StyleTemplate[];\n  availableCredits: number;\n}\n\nexport function NewProductForm({\n  categories,\n  styleTemplates,\n  availableCredits,\n}: NewProductFormProps) {\n  const router = useRouter();\n\n  const [formData, setFormData] = useState({\n    name: \"\",\n    category: \"\",\n    description: \"\",\n    shootingRequirements: \"\",\n    stylePreference: styleTemplates[0]?.id || \"\",\n    specialNotes: \"\",\n    deliveryCount: 6,\n  });\n\n  const [sourceImages, setSourceImages] = useState<\n    { id: string; url: string; file: File }[]\n  >([]);\n  const [uploading, setUploading] = useState(false);\n  const [submitting, setSubmitting] = useState(false);\n  const [error, setError] = useState(\"\");\n\n  const handleChange = (\n    e: React.ChangeEvent<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>\n  ) => {\n    setFormData((prev) => ({\n      ...prev,\n      [e.target.name]: e.target.value,\n    }));\n  };\n\n  const handleFileSelect = useCallback(\n    async (e: React.ChangeEvent<HTMLInputElement>) => {\n      const files = Array.from(e.target.files || []);\n      if (files.length === 0) return;\n\n      // Validate files\n      const validTypes = [\"image/jpeg\", \"image/png\", \"image/webp\"];\n      const invalidFiles = files.filter((f) => !validTypes.includes(f.type));\n      if (invalidFiles.length > 0) {\n        setError(\"仅支持 JPG、PNG、WEBP 格式\");\n        return;\n      }\n\n      setUploading(true);\n      setError(\"\");\n\n      try {\n        // Get presigned URLs for each file\n        const imageData = await Promise.all(\n          files.map(async (file) => {\n            const res = await fetch(\"/api/upload/presigned-url\", {\n              method: \"POST\",\n              headers: { \"Content-Type\": \"application/json\" },\n              body: JSON.stringify({\n                fileName: file.name,\n                fileType: file.type,\n              }),\n            });\n\n            if (!res.ok) throw new Error(\"Failed to get upload URL\");\n\n            const { uploadUrl, fileUrl } = await res.json();\n\n            // Upload to OSS\n            await fetch(uploadUrl, {\n              method: \"PUT\",\n              body: file,\n              headers: { \"Content-Type\": file.type },\n            });\n\n            return {\n              id: crypto.randomUUID(),\n              url: fileUrl,\n              file,\n            };\n          })\n        );\n\n        setSourceImages((prev) => [...prev, ...imageData]);\n      } catch (err) {\n        setError(\"图片上传失败，请重试\");\n        console.error(err);\n      } finally {\n        setUploading(false);\n      }\n    },\n    []\n  );\n\n  const removeImage = (id: string) => {\n    setSourceImages((prev) => prev.filter((img) => img.id !== id));\n  };\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    setError(\"\");\n\n    if (!formData.name || !formData.category || !formData.shootingRequirements) {\n      setError(\"请填写所有必填字段\");\n      return;\n    }\n\n    if (sourceImages.length === 0) {\n      setError(\"请至少上传一张产品图片\");\n      return;\n    }\n\n    setSubmitting(true);\n\n    try {\n      // Create product\n      const res = await fetch(\"/api/products\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({\n          ...formData,\n          deliveryCount: parseInt(String(formData.deliveryCount)),\n        }),\n      });\n\n      if (!res.ok) {\n        const data = await res.json();\n        throw new Error(data.error || \"创建产品失败\");\n      }\n\n      const { product } = await res.json();\n\n      // Upload source images metadata\n      await Promise.all(\n        sourceImages.map((img, index) =>\n          fetch(\"/api/products/images\", {\n            method: \"POST\",\n            headers: { \"Content-Type\": \"application/json\" },\n            body: JSON.stringify({\n              productId: product.id,\n              url: img.url,\n              fileName: img.file.name,\n              fileSize: img.file.size,\n              mimeType: img.file.type,\n              sortOrder: index,\n            }),\n          })\n        )\n      );\n\n      router.push(`/products/${product.id}`);\n    } catch (err) {\n      setError(err instanceof Error ? err.message : \"创建产品失败\");\n    } finally {\n      setSubmitting(false);\n    }\n  };\n\n  return (\n    <form onSubmit={handleSubmit} className=\"space-y-6\">\n      {error && (\n        <div className=\"p-4 bg-red-50 text-red-600 rounded-lg\">{error}</div>\n      )}\n\n      {/* Basic Info */}\n      <div className=\"bg-white rounded-xl p-6 shadow-sm space-y-4\">\n        <h2 className=\"text-lg font-semibold text-[#4E342E]\">基本信息</h2>\n\n        <div>\n          <Label htmlFor=\"name\">产品名称 *</Label>\n          <Input\n            id=\"name\"\n            name=\"name\"\n            value={formData.name}\n            onChange={handleChange}\n            placeholder=\"例如：2024春季新款连衣裙\"\n            required\n            className=\"mt-1\"\n          />\n        </div>\n\n        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n          <div>\n            <Label htmlFor=\"category\">产品类目 *</Label>\n            <select\n              id=\"category\"\n              name=\"category\"\n              value={formData.category}\n              onChange={handleChange}\n              required\n              className=\"mt-1 w-full px-3 py-2 border border-gray-300 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-[#FDD835]\"\n            >\n              <option value=\"\">请选择类目</option>\n              {categories.map((cat) => (\n                <option key={cat.value} value={cat.value}>\n                  {cat.label}\n                </option>\n              ))}\n            </select>\n          </div>\n\n          <div>\n            <Label htmlFor=\"deliveryCount\">期望交付数量</Label>\n            <Input\n              id=\"deliveryCount\"\n              name=\"deliveryCount\"\n              type=\"number\"\n              min={1}\n              max={20}\n              value={formData.deliveryCount}\n              onChange={handleChange}\n              className=\"mt-1\"\n            />\n          </div>\n        </div>\n\n        <div>\n          <Label htmlFor=\"description\">产品描述</Label>\n          <textarea\n            id=\"description\"\n            name=\"description\"\n            value={formData.description}\n            onChange={handleChange}\n            placeholder=\"补充产品特点、材质等信息（选填）\"\n            rows={3}\n            className=\"mt-1 w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#FDD835]\"\n          />\n        </div>\n      </div>\n\n      {/* Source Images */}\n      <div className=\"bg-white rounded-xl p-6 shadow-sm space-y-4\">\n        <h2 className=\"text-lg font-semibold text-[#4E342E]\">产品图片</h2>\n        <p className=\"text-sm text-gray-500\">\n          上传产品原图，AI 将基于这些图片生成商品图\n        </p>\n\n        <div className=\"grid grid-cols-2 md:grid-cols-4 gap-4\">\n          {sourceImages.map((img) => (\n            <div key={img.id} className=\"relative aspect-square rounded-lg overflow-hidden bg-gray-100\">\n              <Image\n                src={img.url}\n                alt=\"Product image\"\n                fill\n                className=\"object-cover\"\n              />\n              <button\n                type=\"button\"\n                onClick={() => removeImage(img.id)}\n                className=\"absolute top-1 right-1 w-6 h-6 bg-black/50 text-white rounded-full text-sm hover:bg-black/70\"\n              >\n                ×\n              </button>\n            </div>\n          ))}\n\n          <label className=\"aspect-square rounded-lg border-2 border-dashed border-gray-300 flex flex-col items-center justify-center cursor-pointer hover:border-[#FDD835] transition-colors\">\n            <span className=\"text-3xl text-gray-400\">+</span>\n            <span className=\"text-sm text-gray-500 mt-1\">上传图片</span>\n            <input\n              type=\"file\"\n              accept=\"image/jpeg,image/png,image/webp\"\n              multiple\n              onChange={handleFileSelect}\n              className=\"hidden\"\n              disabled={uploading}\n            />\n          </label>\n        </div>\n\n        {uploading && (\n          <p className=\"text-sm text-gray-500\">上传中...</p>\n        )}\n      </div>\n\n      {/* Requirements */}\n      <div className=\"bg-white rounded-xl p-6 shadow-sm space-y-4\">\n        <h2 className=\"text-lg font-semibold text-[#4E342E]\">拍摄需求</h2>\n\n        <div>\n          <Label htmlFor=\"shootingRequirements\">详细需求 *</Label>\n          <textarea\n            id=\"shootingRequirements\"\n            name=\"shootingRequirements\"\n            value={formData.shootingRequirements}\n            onChange={handleChange}\n            placeholder=\"请详细描述您的拍摄需求，如：场景、角度、光线、背景等\"\n            rows={4}\n            required\n            className=\"mt-1 w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#FDD835]\"\n          />\n        </div>\n\n        <div>\n          <Label>选择风格</Label>\n          <div className=\"grid grid-cols-2 md:grid-cols-3 gap-3 mt-2\">\n            {styleTemplates.map((style) => (\n              <label\n                key={style.id}\n                className={`relative rounded-lg border-2 cursor-pointer overflow-hidden transition-colors ${\n                  formData.stylePreference === style.id\n                    ? \"border-[#FDD335] ring-2 ring-[#FDD335]/30\"\n                    : \"border-gray-200 hover:border-gray-300\"\n                }`}\n              >\n                <input\n                  type=\"radio\"\n                  name=\"stylePreference\"\n                  value={style.id}\n                  checked={formData.stylePreference === style.id}\n                  onChange={handleChange}\n                  className=\"sr-only\"\n                />\n                <div className=\"aspect-video bg-gray-100 flex items-center justify-center\">\n                  {style.thumbnailUrl ? (\n                    <Image\n                      src={style.thumbnailUrl}\n                      alt={style.name}\n                      fill\n                      className=\"object-cover\"\n                    />\n                  ) : (\n                    <span className=\"text-2xl\">🎨</span>\n                  )}\n                </div>\n                <div className=\"p-2 bg-white\">\n                  <p className=\"font-medium text-sm text-[#4E342E]\">\n                    {style.name}\n                  </p>\n                  {style.description && (\n                    <p className=\"text-xs text-gray-500 line-clamp-1\">\n                      {style.description}\n                    </p>\n                  )}\n                </div>\n              </label>\n            ))}\n          </div>\n        </div>\n\n        <div>\n          <Label htmlFor=\"specialNotes\">特别注意事项</Label>\n          <textarea\n            id=\"specialNotes\"\n            name=\"specialNotes\"\n            value={formData.specialNotes}\n            onChange={handleChange}\n            placeholder=\"任何需要特别注意的事项（选填）\"\n            rows={2}\n            className=\"mt-1 w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#FDD835]\"\n          />\n        </div>\n      </div>\n\n      {/* Submit */}\n      <div className=\"flex items-center justify-between bg-gray-50 rounded-xl p-4\">\n        <div>\n          <p className=\"text-sm text-gray-600\">消耗点数</p>\n          <p className=\"text-lg font-semibold text-[#4E342E]\">1 点</p>\n        </div>\n        <div className=\"text-right\">\n          <p className=\"text-sm text-gray-600\">可用点数</p>\n          <p className=\"text-lg font-semibold text-[#4E342E]\">\n            {availableCredits} 点\n          </p>\n        </div>\n      </div>\n\n      <Button\n        type=\"submit\"\n        disabled={submitting || uploading}\n        className=\"w-full py-3 bg-[#FDD835] text-[#4E342E] font-semibold rounded-lg hover:bg-[#FDD835]/90 disabled:opacity-50\"\n      >\n        {submitting ? \"创建中...\" : \"创建产品\"}\n      </Button>\n    </form>\n  );\n}\n","numLines":399,"startLine":1,"totalLines":399}}}
